export Clamp is Template_FunctionDeclaration
(
    Params = [parValue is Template_Alias(), parMin is Template_Alias(), parMax is Template_Alias()]
    Code = min[parMax, max[parValue, parMin]]
)
//-----------------------------------------------------------------------------
export AttackSustainDecay is Template_FunctionDeclaration // TODO remplacer par UNE fonction plus générique (cf. TUIAnimFactor::MapToLinearSmoothedRect)
(
    Params = [parFactor is Template_Alias(), parSustainStart is Template_Alias(), parSustainEnd is Template_Alias()]
    sustainStart is min[parSustainStart, parSustainEnd]
    sustainEnd is max[parSustainStart, parSustainEnd]
    Code = min[$/System/EvaluableIntrinsics/Attack[parFactor, sustainStart], $/System/EvaluableIntrinsics/Decay[parFactor, sustainEnd]]
)
//-----------------------------------------------------------------------------
export CurvedRamp is Template_FunctionDeclaration // TODO généralisable pour plus d'utilité
(
    Params = [ parX is Template_Alias(), parAlpha is Template_Alias()]
    alphaSq is parAlpha * parAlpha
    Code = - ((alphaSq - 2 * parAlpha + 1)  * parX) div ((2*parAlpha - 1) * parX - alphaSq)
)
//-----------------------------------------------------------------------------
export Reflect is Template_FunctionDeclaration
(
    Params = [parVector is Template_Alias(), parNormal is Template_Alias()]
    Code = (parVector - parNormal * (2.0 * Dot[parVector, parNormal]))
)
//-----------------------------------------------------------------------------
export RandomCircularArc is Template_FunctionDeclaration
(
    Params = [parAngleMin is Template_Alias(), parAngleMax is Template_Alias()]
    Code = getXY0[CosSin[ RandomRange[parAngleMin, parAngleMax] * TConstantFloat(Value = 2*3.14159265)]]
)
//=============================================================================
// Les fonctions MapToXxx sont à support dans [0, 1] et à valeurs dans [0, 1]
//-----------------------------------------------------------------------------
export MapToLinearSmoothStep is Template_FunctionDeclaration
(
    Params = [parFactor is Template_Alias(), t0 is Template_Alias(), t1 is Template_Alias()]
    //++ Projection sur les préconditions
    epsilon is 0.000000001
    t1mt0 is Max[t1 - t0, epsilon]
    //--
    a is (parFactor - t0) div t1mt0 // fonction affine : t0 -> 0, t1 -> 1
    Code = Min[1., Max[0., a]]
)
//-----------------------------------------------------------------------------
export MapToLinearSmoothRect is Template_FunctionDeclaration
(
    Params = [parFactor is Template_Alias(), t0 is Template_Alias(), t1 is Template_Alias(), t2 is Template_Alias(), t3 is Template_Alias()]

    //++ Projection sur les préconditions
    epsilon is 0.000000001
    t1mt0 is Max[t1 - t0, epsilon]
    t2mt3 is Min[t2 - t3, -epsilon]
    //--
    a is (parFactor - t0) div t1mt0 // fonction affine : t0 -> 0, t1 -> 1
    b is (parFactor - t3) div t2mt3 // fonction affine : t2 -> 1, t3 -> 0
    Code = Min[1., Max[0., Min[a, b]]]
)
//-----------------------------------------------------------------------------
export MapToSquareDecelerated is Template_FunctionDeclaration
(
    Params = [parFactor is Template_Alias()]

    Code = 1 - sqr[1 - parFactor]
)
//-----------------------------------------------------------------------------
export MapToSquareAccelerated is Template_FunctionDeclaration
(
    Params = [parFactor is Template_Alias()]

    Code = sqr[parFactor]
)
//-----------------------------------------------------------------------------
export MapToParabolicArch is Template_FunctionDeclaration
(
    Params = [parFactor is Template_Alias()]

    Code = 4 * (parFactor - parFactor * parFactor)
)
//=============================================================================
export PhysicComputePosition_Simple is Template_FunctionDeclaration
(
    Params =
    [
        parParticleAcceleration is Template_Alias(ExpectedType : float3),
        parSpeed is Template_Alias(ExpectedType : float3),
        parPosition is Template_Alias(ExpectedType : float3),
    ]

    // Intégration de d²x/dt² = a, en considérant a constant : X = x0 + v0 * t + 1/2 * a * t²
    // C'est le DL à l'ordre 2 de la position => l'erreur est en o(t²), mais peut devenir tres grande si a varie beaucoup.
    // Marche cependant de maniere exacte pour un déplacement uniquement soumis à une gravité constante.
    Code = parPosition + parSpeed * ~/EvolverDt + 0.5 * parParticleAcceleration * ~/EvolverDt * ~/EvolverDt
)
//------------------------------------------------------------------------------
export PhysicComputeSpeed_Simple is Template_FunctionDeclaration
(
    Params =
    [
        parParticleAcceleration is Template_Alias(ExpectedType : float3),
        parSpeed is Template_Alias(ExpectedType : float3),
    ]
    // intégration de d²v/dt² = a, en considérant a constant : V = v0 + a * t
    // (intégration d'Euler)
    Code = parSpeed + parParticleAcceleration * ~/EvolverDt
)
//------------------------------------------------------------------------------
export maxDistance is 500000

export FxLodLevel is (1 - sat[length[MobilePosition - CameraPosition] div maxDistance]) * FxQuality

export FxLodLevel_For_Particle is (1 - sat[length[ParticlePosition - CameraPosition] div maxDistance]) * FxQuality

export minValueForFxLodLevel is lerp[FxQuality, 0.25, 0.5]
export FxLodLevel_from_05to1 is lerp[FxLodLevel, minValueForFxLodLevel, 1.0]
export FxLodLevel_from_005to1 is lerp[FxLodLevel, 0.05, 1.0]
