export sqr is                               Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/sqr)
export rsqrt is                             Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/rsqrt)
export rcp is                               Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/rcp)
export exp is                               Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/exp)
export ceil is                              Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/ceil)
export floor is                             Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/floor)
export round is                             Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/round)
export sign  is                             Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/sign)
export Creneau is                           Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/creneau)
export Sinusoid is                          Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/sinusoid)
export Sawtooth is                          Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/sawtooth)
