export MinusOneToOneRandomBoxVolume is          Template_AparametricFunction_ForBank ( Function = 'MinusOneToOneRandomBoxVolume')

export OrientAndNarrowRandomValue is            Template_FunctionDeclaration ( Code = (parRandomFunction + normalized[parCenterAxis] * parNarowness) div (1 + parNarowness) Params = [parRandomFunction is Template_Alias(), parCenterAxis is Template_Alias(), parNarowness is Template_Alias()])
export NarrowRandomValue is                     Template_FunctionDeclaration ( Code = OrientAndNarrowRandomValue[parRandomnessFunction, float3[0,0,1], parNarownessPower] Params = [parRandomnessFunction is Template_Alias(), parNarownessPower is Template_Alias()])

