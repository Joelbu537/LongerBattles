// numero de version pour forcer la regeneration des Fx. a incrementer quand on en a besoin :
// Fx Glad Version = 0
export negate is           Template_FunctionDeclaration( Params = [a is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/negate)

export FxQuality is             ($/GraphicOption/FxQuality/Value div 100)
export FxQualityLowest is       TConstantFloat(Value = 0)
export FxQualityVeryLow is      TConstantFloat(Value = 0.2)
export FxQualityLow is          TConstantFloat(Value = 0.4)
export FxQualityMid is          TConstantFloat(Value = 0.6)
export FxQualityHigh is         TConstantFloat(Value = 0.7)
export FxQualityMax is          TConstantFloat(Value = 1)

FXVerticalWindSpeed is float3[0,0,100]

WeatherWindDirection is TVariable
(
    Object = $/M3D/Environment/GlobalLightingEnvironment
    PropertyName = 'ActiveWindMovementForFx'
    Variability = $/Variability/Frame
)

export MapWind is FXVerticalWindSpeed + WeatherWindDirection


// binary functions
export Distance                     is  Template_FunctionDeclaration ( Params = [a is Template_Alias(), b is Template_Alias()]                       Intrinsic = $/System/EvaluableIntrinsics/distance)
export Dot                          is  Template_FunctionDeclaration ( Params = [a is Template_Alias(), b is Template_Alias()]                       Intrinsic = $/System/EvaluableIntrinsics/dot)
export Cross                        is  Template_FunctionDeclaration ( Params = [a is Template_Alias(), b is Template_Alias()]                       Intrinsic = $/System/EvaluableIntrinsics/cross)
export Pow                          is  Template_FunctionDeclaration ( Params = [a is Template_Alias(), b is Template_Alias()]                       Intrinsic = $/System/EvaluableIntrinsics/pow)
export Mod                          is  Template_FunctionDeclaration ( Params = [a is Template_Alias(), b is Template_Alias()]                       Intrinsic = $/System/EvaluableIntrinsics/mod)
export Min                          is  Template_FunctionDeclaration ( Params = [a is Template_Alias(), b is Template_Alias()]                       Intrinsic = $/System/EvaluableIntrinsics/min)
export Max                          is  Template_FunctionDeclaration ( Params = [a is Template_Alias(), b is Template_Alias()]                       Intrinsic = $/System/EvaluableIntrinsics/max)

export RandomUnit                   is  Template_AparametricFunction_ForBank (Function = 'UnitRand')
export RandomRange                  is  Template_FunctionDeclaration ( Params = [parMin is Template_Alias(), parMax is Template_Alias()]             Code = parMin + (RandomUnit*(parMax - parMin)))
export RandomRangePivot             is  Template_FunctionDeclaration ( Params = [a is Template_Alias(), b is Template_Alias()]                       Code = a + b * (RandomUnit - 0.5))
export RandomRangeSymetric          is  Template_FunctionDeclaration ( Params = [a is Template_Alias(), b is Template_Alias()]                       Code = ifte[RandomUnit > 0.5, RandomRange[a,b], -RandomRange[a,b]])

// Deprecated
export AttackDecay                  is  Template_FunctionDeclaration ( Params = [parInput is Template_Alias(), parMaxValuePos is Template_Alias()]   Intrinsic = $/System/EvaluableIntrinsics/AttackDecay)
export Attack                       is  Template_FunctionDeclaration ( Params = [parInput is Template_Alias(), parAttackEndPos is Template_Alias()]  Intrinsic = $/System/EvaluableIntrinsics/Attack)
export Decay                        is  Template_FunctionDeclaration ( Params = [parInput is Template_Alias(), parDecayStartPos is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/Decay)

// misc
export CameraPosition is                    Template_CameraPosition_ForBank         ( Camera = $/M3D/Scene/FxCameraProvider_CameraPrincipale)
export CameraDeltaPosition is               Template_CameraDeltaPosition_ForBank    ( Camera = $/M3D/Scene/FxCameraProvider_CameraPrincipale)
export CameraDirection is                   Template_CameraDirection_ForBank        ( Camera = $/M3D/Scene/FxCameraProvider_CameraPrincipale)
export CameraAxeX is                        Template_CameraAxeX_ForBank             ( Camera = $/M3D/Scene/FxCameraProvider_CameraPrincipale)
export CameraAxeY is                        Template_CameraAxeY_ForBank             ( Camera = $/M3D/Scene/FxCameraProvider_CameraPrincipale)
export MousePosition is                     Template_MousePosition_ForBank          ( World = $/M3D/Scene/DefaultWorld)
export MobileWrapper is                     Template_ActionDependentValue_ForBank   ( ValueName = 'MobileWrapper' ExpectedType : PClassWithVirtualDestructor)
export MobilePosition is                    Template_ActionDependentValue_ForBank   ( ValueName = 'MobilePosition' ExpectedType : float3)
export MobileDirection is                   Template_ActionDependentValue_ForBank   ( ValueName = 'MobileDirection' ExpectedType : float3)
export ifte is                              Template_FunctionDeclaration(           Intrinsic = $/System/EvaluableIntrinsics/ifte Params = [Template_Alias(), Template_Alias(), Template_Alias()])
export ToFloat3 is                          Template_FunctionDeclaration            ( Intrinsic = $/System/EvaluableIntrinsics/GenFloat3 Params = [Template_Alias()])
export ToString is                          Template_FunctionDeclaration            ( Intrinsic = $/System/EvaluableIntrinsics/ToString Params = [Template_Alias()])
export ToInt is                             Template_FunctionDeclaration            ( Intrinsic = $/System/EvaluableIntrinsics/ToInt Params = [Template_Alias()])
export TimeInSecondsNonPausable is          Template_TimeInSecondsNonPausable_ForBank ()
export ActionLifeRatio is                   Template_ActionDependentValue_ForBank   ( ValueName = 'LifeRatio' ExpectedType : float)
export ActionRemainingLifeRatio is          (1 - TActionDependentValue(Name = 'LifeRatio' ExpectedType : float))
export ActionElapsedTime is                 Template_ActionDependentValue_ForBank   ( ValueName = 'ElapsedTime' ExpectedType : float)
export PI is                                TConstantFloat(Value = 3.1415927)
export PI2 is                               TConstantFloat(Value = 3.1415927 * 2)
export OOPI2 is                             TConstantFloat(Value = 1. div (3.1415927 * 2) )

// random vector
export PositiveUnitRandomDisc is                Template_AparametricFunction_ForBank ( Function = 'PositiveUnitRandomDisc')
export PositiveUnitRandomSphereVolume is        Template_AparametricFunction_ForBank ( Function = 'PositiveUnitRandomSphereVolume')
export PositiveUnitRandomHemisphereVolume is    Template_AparametricFunction_ForBank ( Function = 'PositiveUnitRandomHemisphereVolume')
