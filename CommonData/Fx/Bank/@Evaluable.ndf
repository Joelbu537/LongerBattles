export CurrentParticleDirection is                             Template_ParticleAccessor_ForBank (Field = $/Particle/Direction Indexed = true)

private IntrinsicOperatorRotationFromVectorXY is                Template_NamedUnaryIntrinsic_ForBank(Operator = 'RotationFromVectorXY')
private IntrinsicOperatorAltitudeRelative is                    Template_NamedUnaryIntrinsic_ForBank(Operator = 'AltitudeRelative')
private IntrinsicOperatorMobileWrapperPosition is               Template_NamedUnaryIntrinsic_ForBank(Operator = 'MobileWrapperPosition')
private IntrinsicOperatorPositionUnScaled is                    TNamedBinaryIntrinsic(Operator = 'PositionUnScaled')
private IntrinsicOperatorMobileWrapperAxeX is                   Template_NamedUnaryIntrinsic_ForBank(Operator = 'MobileWrapperAxeX')
private IntrinsicOperatorMobileWrapperAxeY is                   Template_NamedUnaryIntrinsic_ForBank(Operator = 'MobileWrapperAxeY')
private IntrinsicOperatorMobileWrapperAxeZ is                   Template_NamedUnaryIntrinsic_ForBank(Operator = 'MobileWrapperAxeZ')
private IntrinsicOperatorMobileWrapperScale is                  Template_NamedUnaryIntrinsic_ForBank(Operator = 'MobileWrapperScale')

// Convertions srgb->lineaires pour faire les calculs en lineaire
export LinearColor255 is                    Template_FunctionDeclaration ( Params = [R is Template_Alias(), G is Template_Alias(), B is Template_Alias()] Code = LinearColor[R div 255.0, G div 255.0, B div 255.0] ) // 1 div 255

// unary functions
export abs is                               Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/abs)
export sin is                               Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/sin)
export cos is                               Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/cos)
export CosSin is                            Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/CosSin)
export acos is                              Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/acos)
export asin is                              Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/asin)
export atan is                              Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/atan)
export tan is                               Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/tan)
export log is                               Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = $/System/EvaluableIntrinsics/log)
