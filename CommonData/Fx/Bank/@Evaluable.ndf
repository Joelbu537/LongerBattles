export MobileWrapperAxeY is                 Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = ~/IntrinsicOperatorMobileWrapperAxeY)
export MobileWrapperAxeZ is                 Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = ~/IntrinsicOperatorMobileWrapperAxeZ)
