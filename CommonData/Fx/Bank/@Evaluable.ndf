export RotationFromVectorXY is              Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = ~/IntrinsicOperatorRotationFromVectorXY)
export CentroidAltitudeRelative is          Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = ~/IntrinsicOperatorAltitudeRelative)
export MobileWrapperPosition is             Template_FunctionDeclaration ( Params = [param is Template_Alias()] Intrinsic = ~/IntrinsicOperatorMobileWrapperPosition)
export MobileWrapperPositionUnScaled is     Template_FunctionDeclaration ( Params = [mobile is Template_Alias(), centroid is Template_Alias()] Code = PositionUnScaled[IntrinsicOperatorMobileWrapperPosition[mobile], centroid])
