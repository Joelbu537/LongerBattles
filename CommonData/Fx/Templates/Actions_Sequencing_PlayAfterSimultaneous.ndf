template Template_PlayAfterSimultaneous
[
    LocalVariables              : LIST<TPinnableValue> = [],
    Mobile                      : TMobileFactory = nil,
    Actions                     : LIST<TActionDescriptor> = [],
    WaitInSeconds               : TEvaluable = TConstantFloat(Value = 1.0),
    Disabled                    : TEvaluable = nil,
    TimeServer                  : TTimeServerWithVisibilityRange = nil,
] is TSequentialAction
(
    Actions =
       <Mobile> == nil
        ? ([TWaitInSec(Duration = <WaitInSeconds>)] + <Actions>)
        :
        [
            TWaitInSec(Duration = <WaitInSeconds>),
            TSimultaneousAction
            (
                Actions = <Actions>
                Mobile = <Mobile>
            )
        ]
    Mobile = nil
    Disabled = <Disabled>
    LocalVariables = <LocalVariables>
    TimeServer = <TimeServer>
)


template Template_RepeatPlayAfterSimultaneous
[
    LocalVariables              : LIST<TPinnableValue> = [],
    Mobile                      : TMobileFactory = nil,
    Actions                     : LIST<TActionDescriptor> = [],
    IterationCount              : TEvaluable = nil,
    WaitBetweenRepeats          : TEvaluable = TConstantFloat(Value = 0.0),
    Forever                     : TEvaluable = TConstantBool(Value = false),
    WaitInSeconds               : TEvaluable = TConstantFloat(Value = 1.0),
    Disabled                    : TEvaluable = nil,
    TimeServer                  : TTimeServerWithVisibilityRange = nil,
] is TSequentialAction
(
    Actions =
        <IterationCount> == nil & <Mobile> == nil
        ? ([TWaitInSec(Duration = <WaitInSeconds>)] + <Actions>)
        :
        [
            TWaitInSec(Duration = <WaitInSeconds>),
            TRepeatSimultaneousAction
            (
                Actions = <Actions>
                Mobile = <Mobile>
                IterationCount = <IterationCount>
                WaitBetweenRepeats = <WaitBetweenRepeats>
                InfiniteLoop = <Forever>
            )
        ]
    Mobile = nil
    Disabled = <Disabled>
    LocalVariables = <LocalVariables>
    TimeServer = <TimeServer>
)
