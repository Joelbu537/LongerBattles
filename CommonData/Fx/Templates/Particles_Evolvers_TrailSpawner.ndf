template TrailSpawner
[
    DistanceBetweenSpawn                : TEvaluable = TConstantFloat(Value = 500.0),
    Spawner                             : TParticleSpawner[required] = nil,
    Condition                           : TEvaluable = nil,
    Disabled                            : boolean = false,
    ForceSlicing                        : boolean = false,
    PreviousEvolverSpawnPositionField   : TParticleSubPart = nil,
    SpawnStartedField                   : TParticleSubPart = nil,
    UseGameEngineUnits                  : boolean = false,
] is TParticleEvolver_TrailSpawner
(
    DistanceBetweenSpawn = <DistanceBetweenSpawn>
    Spawner = <Spawner>
    Disabled = <Disabled>
    Condition = <Condition>
    ForceSlicing = <ForceSlicing>
    SpawnStartedField = <SpawnStartedField> == nil? $/Particle/SpawnStarted : <SpawnStartedField>
    PreviousEvolverSpawnPositionField = <PreviousEvolverSpawnPositionField> == nil ? $/Particle/PreviousEvolverSpawnPosition : <PreviousEvolverSpawnPositionField>
    UseGameEngineUnits = <UseGameEngineUnits>
)

// Si on n'utilise pas les champs par defaut il faut initialiser les valeurs des champs avec ce post-Initaliser.
template Template_Post_Initialiser_For_EvolverTrailSpawner
[
    SpawnStartedField                   : TParticleSubPart[Required] = nil,
    PreviousEvolverSpawnPositionField   : TParticleSubPart[Required] = nil
] is TParticleInitialiserList
(
    Initialisers =
    [
        TParticleInitialiserWithEvaluable(Field = <SpawnStartedField>                   InitFunction = false),
        TParticleInitialiserWithEvaluable(Field = <PreviousEvolverSpawnPositionField>   InitFunction = ParticlePosition)
    ]
)
