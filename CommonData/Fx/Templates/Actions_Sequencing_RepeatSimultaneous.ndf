template Template_RepeatSimultaneous
[
    LocalVariables                  : LIST<TPinnableValue> = [],
    Mobile                          : TMobileFactory = nil,
    Actions                         : LIST<TActionDescriptor> = [],
    IterationCount                  : TEvaluable = TConstantInteger(Value = 1),
    WaitBetweenRepeats              : TEvaluable = TConstantFloat(Value = 0.0),
    Disabled                        : TEvaluable = nil,
    Forever                         : TEvaluable = TConstantBool(Value = false),
    TimeServer                      : TTimeServerWithVisibilityRange = nil,
] is TRepeatSimultaneousAction
(
    Actions = <Actions>
    Mobile = <Mobile>
    IterationCount = <IterationCount>
    WaitBetweenRepeats = <WaitBetweenRepeats>
    Disabled = <Disabled>
    InfiniteLoop = <Forever>
    LocalVariables = <LocalVariables>
    TimeServer = <TimeServer>
)
