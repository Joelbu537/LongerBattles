template Template_ShakeCamera
[
    Power_0to1        : TEvaluable = nil,
    DurationInSec     : TEvaluable = nil,
    PeriodInSec       : TEvaluable = TConstantFloat(Value = 0.1),
    Disabled          : TEvaluable = nil,
] is TShakeCameraActionDescriptor
(
    Power_0to1 = <Power_0to1>
    ShakeCameraManager = $/Camera/ShakeCameraManager
    DurationInSec = <DurationInSec>
    PeriodInSec = <PeriodInSec>
    Disabled = <Disabled>
)
