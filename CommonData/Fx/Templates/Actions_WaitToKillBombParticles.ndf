template Template_WaitToKillBombParticle
[
    MaxWaitDuration         : TEvaluable[GroupBy = "Spawn parameters"] = TConstantInteger(Value = 10),
    BombSpawner             : TParticleSpawnerActionBomb[required] = nil,
    Forever                 : boolean = false,
    Disabled                : TEvaluable = nil,
] is TWaitToKillBombParticles
(
    MaxWaitDuration = <MaxWaitDuration>
    BombSpawner = <BombSpawner>
    Forever = <Forever>
    Disabled = <Disabled>
)
