///!\ BITTE DIE ALPHABETISCHE REIHENFOLGE EINHALTEN !
// Nach Kategorien, dann nach Konstante.

//---------------------------------------------------------------------------------------//
//---------------------------------------------------------------------------------------//
//----------------------------------- ALLGEMEIN -----------------------------------------//
//---------------------------------------------------------------------------------------//
//---------------------------------------------------------------------------------------//

Constantes is TTunableConstante
(
    // /!\ BITTE DIE ALPHABETISCHE REIHENFOLGE EINHALTEN !
    // Nach Kategorien, dann nach Konstante.

//--------------------------- Anzeige-Konstanten ---------------------------------------//

    EliminationWarningsDuration = 5.0

//------------------------ Konstanten Automatisches Verhalten ----------------------------//

    AutoCover_DistanceMaxEntreLesChecksDeTerrainsGRU = 21 // Abstand zwischen Geländesamples, um zu prüfen, ob Autocover durchgeführt wird.
    AutoCover_TagEmpechantLAutocover = "Infanterie_Cowering"
    MaxPullDistanceGRU = 353
    MaxPullDistanceForAirplaneGRU = 17667
    TagBloquantLeMoveAndAttack = "Bloque_MoveAndAttack" // Wenn dieses Tag gesetzt ist, stoppt die Einheit ihr Move-and-Attack; die Aktion wird fortgesetzt, wenn das Tag entfernt wird.
    TempsEnSecondesEntreDeuxSmokeAutomatiques = 1
    AutoSmokeQuandRatioPvInferieurA = 1.0
    RatioPuissancePourRetaliation = 1.0
    TireursIgnoreesPourLaFuite = ["Artillerie", "Avion"]


//----------------------------- Flugzeug-Konstanten ------------------------------------//

    CadavreOffsetMax = 0.3  // 0.33
    CadavreOffsetMin = 0.1 // 0.18

//--------------------------- Gebäude-Konstanten ---------------------------------------//

    UnitPositionVerticalOffsetFromRoofGRU = -21

//--------------------------- Beacon-Konstanten ---------------------------------------//
    BeaconAlphaGhost = 0.3
    BeaconMaxCount = 4
    BeaconTimeout = 60.0

//----------------------------- Kampf-Konstanten ----------------------------------------//

    ReductionDegatsSuppressDansVehicule = 0.50 // Prozentsatz der Suppress-Schäden, die ein Fahrzeug erhält und auf transportierte Einheiten angewendet werden.
    TagRadioArtillerie = "Radio"
    TagRadioJammed = "RadioJammed"
    PorteeRadioArtillerieGRU = 2120
    EfficiencyShotSearchDistanceTolerance = 100.0
    PerteDeSuppressParPointDeVieEntierPerdu = 0.0
    StunEffectDuration = 4.0

//----------------------------- Kommandeur-Konstanten -----------------------------------//

    CommanderEffect = $/GFX/EffectCapacity/UnitEffect_Gain_un_niveau_XP

    CommanderRadiusEffectByLevelGRU =
    [
        424,
        565,
        636,
    ]

//------------------------------ Korridor-Konstanten -----------------------------------//
    CanUseAlliedAllianceCorridors = false

//------------------------------ Gameplay-Konstanten -----------------------------------//

    Persistance_Bruit = 16.5

//---------------------------- Spielregel-Konstanten -------------------------------------//

    // Konvention, die bestimmt, welche Allianz die angreifende Allianz ist, wenn der Spielmodus dies zulässt.
    // Wenn zu Beginn einer Partie die angreifende Allianz nicht die hier angegebene ist, müssen wahrscheinlich die Spawn-Punkte angepasst werden.
    BaseAttackingAllianceNum = 0

    DefaultAIDifficultyForPlayerReplacement = IADifficulty/Normal

    SuddenDeathTime = 5 * 60
    MinimumNumberOfUnitToStayInGameWithoutCmdOrProductionInDestructionMode = 5

    TacticVictoryLevelConstantes = ~/TacticVictoryLevelConstantes

//------------------------- Formation-Verwaltungs-Konstanten ----------------------------//

    DistanceCoherenceGRU = 1766

//-------------------------- Hubschrauber-Konstanten ------------------------------------//
    // Maximaler Winkel zur Richtung (0,0,1) IN GRAD -- MUSS > 0 SEIN (ansonsten wird es vermutlich schiefgehen) -- VOR ÄNDERUNG MIT EINEM ENTWICKLER ABKLÄREN, DA SEHR SENSIBEL!!!
    // Überschreitet man diesen Wert, kann der Hubschrauber Schwierigkeiten haben, sich in die richtige Landerichtung zu orientieren und nie die richtige Befehlssequenz zum Landen finden.
    // Eine Lösung wäre, die Steuerbefehle zurückzusetzen, um den Algorithmus neu zu starten, aber das kann Auswirkungen auf andere Bewegungen haben; daher nur bei Bedarf.
    MaxTerrainAngleForLanding = 8

    // Abstand für kleine Bewegungen (in Metern). Definiert die maximale Bewegungsdistanz eines Hubschraubers für:
    // - Verbleib in sehr niedriger Höhe.
    DistanceMaxSmallMovementsInMeters = 150

    // Zeit zur Vorhersage der Landeposition der Hubschrauber. Für schwere Hubschrauber drehen sie trotzdem um; eine genaue Berechnung der Abbremszeit fehlt, daher wird eine Heuristik verwendet.
    LandingPositionTimePredictionInSeconds = 3.2

//-------------------------- Infanterie-Konstanten ------------------------------------//
// Anzahl Soldaten in der Anzeige der Steelman-Symbole
    ShowroomOffsetBetweenLines = 518.0
    ShowroomOffsetBetweenSoldiers = 500.0
    ShowroomNumberOfLines = 2
    ShowroomMinSoldiersPerLine = 4


//-------------------------- Interface-Konstanten -------------------------------------//

    // Standardfarbe der Geister
    DefaultGhostColors = TGhostColors(
        GhostColor = [255, 255, 255, 255]
        GhostAlphas = [0.4, 0.2]
        GhostBlends = [1, 0.1]
    )

//---------------------------- Lobby-Konstanten ----------------------------------------//

    // 0 ist Keine Zeitbegrenzung
    TimeLimitTable = [20, 30, 40, 60, 90, 120, 180, 240, 300, 0]
    DefaultTimeLimitInMinutes = 40

//----------------------------- Raketen-Konstanten -------------------------------------//

    TempsAutoriseHorsMondePourMissileSansCible = 5.0

//----------------------------- Bewegungs-Konstanten ------------------------------------//

    AngleArrierePourMarcheArriereEnDegre = 120
    DistancePourDeclencherMarcheArriereGRU = 706
    ForcerMarcheAvantPourAttaquer       = true
    LargeurRouteGRU                        = 21 // Fahrzeugtrajektorien sind um 0.5 * Straßenbreite nach rechts oder links versetzt.
    ToleranceLargeurRoutePourMouvementsRapidesShiftes = 2 // Multiplikator der Straßenbreite, um zu prüfen, ob das Ziel eines MoveFast auf der Straße liegt.
    DecalageDepuisLeCentreDansCouloirGRU   = 3 // Versatz der Wegpunkte der Einheiten relativ zur Mitte des Korridors, wenn eine Einheit diesen durchquert.
    TagDecrochage                       = "Retraite"  // Tag, das verwendet wird, um zu bestimmen, ob das Rückzugs-Label während des Rückzugs angezeigt wird.

//----------------------------- Wiederverkauf-Konstanten ---------------------------------//

    ResaleDistanceGRU = 88
    CooldownBeforeKillInSeconds = 2 // Sekunden

//----------------------------- Auswahl-Konstanten --------------------------------------//

    AllowGhostCrossUnitSelection = true // Auswahl von vorplatzierten Einheiten und Geistern gleichzeitig
    AllowMixedSelection = false // Auswahl von Einheiten UND Gebäuden gleichzeitig?
    AllowMultipleBuildingSelection = false // Mehrfachauswahl von Gebäuden (und Bezirken)

//------------------------- Konstanten für Einheiten außerhalb der Karte ------------------//

    OutmapShootPositionPitch = 69.0
    OutmapShootPositionRelativeAltitude = 100000.0
    OutmapShootPositionYaw = 42.0

//---------------------------- Sichtbarkeits-Konstanten ----------------------------------//

    MultiplicateurBonusDissimulationParDistanceGRU = 0.0283 // = (Entfernung in GRU^-1)
    RelativeScanningHeightGRU = 7.0
)

//------------------------------ Sieg-Konstanten ----------------------------------------//

TacticVictoryLevelConstantes is TVictoryLevelConstantes
(
    MinorVictoryLimit = 0.05  // Verhältnis zwischen dem Score des Siegers und dem zweitbesten Score
    MajorVictoryLimit = 0.55  // Verhältnis zwischen dem Score des Siegers und dem zweitbesten Score
    TotalVictoryLimit = 0.75  // Verhältnis zwischen dem Score des Siegers und dem zweitbesten Score
)

