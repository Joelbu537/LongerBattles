ModernWarfareConstantes is TModernWarfareTunableConstante
(
    LinkToCommonConstantes = ~/Constantes // DEV

    // /!\ BITTE DIE ALPHABETISCHE REIHENFOLGE EINHALTEN !
    // Nach Kategorien, dann nach Konstante.

//---------------------------- Kampf-Konstanten (ModernWarfare) --------------------------//

    DistanceInfanterieEnnemiDetectionGRU = 70
    DistanceRelaunchMouvementForMoveAndAttackGRU = 530 // Distance pour laquelle une unité en MoveAndAttackTarget doit relancer le mouvement si sa cible s'est déplacée de cette distance (diminuer cette valeur baisse la perf)
    DistanceToAddToEnnemiDetectionForAAWeaponGRU = 1400
    DistanceToAddToEnnemiDetectionForAntiProjectileWeaponGRU = 0 // grosso merdo la porté max d'une arme anti-missile
    DistanceToAddToEnnemiDetectionForOtherWeaponGRU = 350
    DureeDeRevelationApresAttaque = 10.0
    FacteurMinTempsViseeReel = 0.75 // Le temps de visée réel est un random entre cette valeur et la valeur de temps de visee théorique située dans l'ODS

    // Mindestreichweite, um eine Waffe als Artillerie zu betrachten. Einheiten versuchen nicht, vor als Artillerie eingestuften Waffen zu fliehen.
    PorteeMinArmeEstConsidereCommeArtillerieGRU = 2296

    // Anzahl der pro Sekunde wiedergewonnenen Suppression-Punkte. Multipliziert mit "<TypeUnite>_SuppressDamagesRegenRatioList" in DamageModules.ndf.
    RegenStressParSeconde = 0.5

    // Eine Einheit wird nur versorgt, wenn sie in den letzten #TempsSansStressPourRegen# Sekunden keinen #SeuilStressPourRegen# erhalten hat.
    TempsSansStressPourRegen = 10 // 10 secondes

    TempsSansTirNiDamagePourPasserHorsCombat = 30 // 1, auf 2 erhöhen, um Grafikfehler zu begrenzen

    TagStunned = "Stunned"
    TagUberstress = "Uberstress"

//---------------------------- Distrikt-Konstanten --------------------------------------//

    FuirDistrictEnFeu = true
    MargePourLesTestsDeSortieDeDistrictLBU = 2
    DurationForLeavingDistrict = 3.0        // Dauer der Aktion zum Verlassen des Distrikts.

//---------------------------- Gameplay-Konstanten (ModernWarfare) ----------------------//

    TransformerAttackEnMoveSiPasDArmeAdaptee = false

//---------------------------- Gruppierte Bewegung-Konstanten ----------------------------//

    ClustersDimensionMaxGRU = 353     // Größe der Einheiten-Cluster zur Auswahl einer gemeinsamen Route für Gruppenbewegungen.

//------------------------ KI-Strategie Konstanten (ModernWarfare) ------------------------//

    // Prozentualer Bonus auf Startgeld nach KI-Schwierigkeit
    RelativeBonusMoneyByIADifficulty = MAP
    [
        (IADifficulty/TresFacile,       0.0),
        (IADifficulty/Facile,           0.0),
        (IADifficulty/Normal,           0.0),
        (IADifficulty/Difficile,        0.0),
        (IADifficulty/TresDifficile,    0.5),
        (IADifficulty/PlusDifficile,    0.8),
    ]

//---------------------------- Bewegungs-Konstanten (ModernWarfare) ---------------------//

    MoteurHelicos_TempsArret = 8
    MoteurHelicos_TempsDemarrage = 4
    MultiplicateurConsommationUnitesArretees = 0.0 // Zwischen 0 und 1

//---------------------------- Tandem-Ladung / ReaktivePanzerung --------------------------//
    // Bonus von Tandemladungen gegen reaktive Panzerung
    TandemModifierValue = 2.0
    TandemModifierType = ModifierType_Additionnel

//----------------------------- Waffen-Konstanten ---------------------------------------//

    AdditionalSuppressDamagePerLostPhysicalDamage = 25 // Das ist ein Multiplikator der physischen Schäden, der auf Stress angewendet wird.

    // http://dl.uncw.edu/digilib/mathematics/algebra/mat111hb/functions/equations/equations.html
    DistanceFriendlyFireGRU = 1  // Entfernung zwischen einem Feind und einem Verbündeten, unterhalb der eine Turm nicht feuert (1000)
    DistanceMinFleeFireGRU = 17 // Minimale Fluchtentfernung einer Einheit in den Flammen (zusätzlich zum Radius der Einheit)

    FrontSideAngleInDeg = 60
    RearSideAngleInDeg = 120

    IgnoreTirPenetrantSiAucunBlindage = true

    ShootingAdjustmentAngleMax = 0.4 //20°
    SplashRatioDamage = [0.35, 0.35, 0.25] // Enum EDamageType damages (zwischen 0 und 1). Verhältnis des Schadens am Rand des Splash-Kreises
    SplashRatioDistance = [0.35, 0.35, 0.30] // Enum EDamageType damages (zwischen 0 und 1). Anteil des Splash-Radius, ab dem der Schaden reduziert wird. Z.B. 0.25 wenn DistanceImpact / SplashRadius > 0.25

    TagAllowedForMissileRoE = "AllowedForMissileRoE"
    TagNonRadarTargetable = "Non_Radar_Targetable"

    // Wenn ein Projektil in einer Ebene explodiert und Splash-Schaden verursacht, werden hier die betroffenen Ebenen definiert
    SplashCollisionPlanes = MAP
    [
        (
            ~/ECollisionPlane/NoCollision,
            [
                ~/ECollisionPlane/NoCollision,
                ~/ECollisionPlane/Ground,
                ~/ECollisionPlane/NearGround,
                ~/ECollisionPlane/LowAltitude,
                ~/ECollisionPlane/HighAltitude,
                ~/ECollisionPlane/ProjectileAltitude,
            ]
        ),
        (
            ~/ECollisionPlane/Ground,
            [
                ~/ECollisionPlane/Ground,
                ~/ECollisionPlane/NearGround,
                ~/ECollisionPlane/ProjectileAltitude,
            ]
        ),
        (
            ~/ECollisionPlane/NearGround,
            [
                ~/ECollisionPlane/Ground,
                ~/ECollisionPlane/NearGround,
                ~/ECollisionPlane/LowAltitude,
                ~/ECollisionPlane/ProjectileAltitude,
            ]
        ),
        (
            ~/ECollisionPlane/LowAltitude,
            [
                ~/ECollisionPlane/NearGround,
                ~/ECollisionPlane/LowAltitude,
                ~/ECollisionPlane/HighAltitude,
                ~/ECollisionPlane/ProjectileAltitude,
            ]
        ),
        (
            ~/ECollisionPlane/HighAltitude,
            [
                ~/ECollisionPlane/LowAltitude,
                ~/ECollisionPlane/HighAltitude,
            ]
        ),
        (
            ~/ECollisionPlane/ProjectileAltitude,
            [
                ~/ECollisionPlane/Ground,
                ~/ECollisionPlane/NearGround,
                ~/ECollisionPlane/ProjectileAltitude,
            ]
        ),
    ]
)

