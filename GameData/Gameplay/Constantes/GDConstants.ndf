WargameConstantes is TWargameTunableConstante
(
    // /!\ MERCI DE RESPECTER L'ORDRE ALPHABETIQUE !
    // Par catégories puis par constante.

//--------------------------- Eroberungs-Modus Konstanten -----------------------------//

    DefaultMoneyWinPerAllianceRateInConquestMode = 3 // mittel
    TimeBeforeEarningConquestPoints = 1.5 // in Sekunden

    // Lokalisierungstoken für Einkommensstufen
    //                                            none         very_low     low         medium      high         very_high
    MoneyWinLocalisationTokensInConquestMode = [ 'CONQ_NONE', 'CONQ_VLOW', 'CONQ_LOW', 'CONQ_MED', 'CONQ_HIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH', 'CONQ_VHIGH' ]

    // Multiplikator der erlangten Commandopunkte pro Spieler pro Periode von TimeBeforeEarningCommandPoints im Eroberungsmodus
    //                                   none  very_low    low   medium   high    very_high
    MoneyWinPerAllianceInConquestMode = [  0,      0.5,   0.75,      1,    1.5,       2,     2.5, 3, 4, 5, 7.5, 10, 20, 30, 50, 100, 999]

    ConquestPossibleScores =
    [
        1000,//1000 par défaut, 1800 (30mn) en limité
        2000,//2000 par défaut, 2100 (35mn) en limité
        4000,//4000 par défaut, 2400 (45mn) en limité
        6000,
        8000,
        10000,
        15000,
        20000
    ]

    CoeffMoneyMaxIfUsingUpkeep = 1.5

//-------------------------- Wirtschaft-Konstanten ------------------------------------//

    BaseIncome = MAP
    [
        (ECombatRule/NotSpecified,   0),
        (ECombatRule/Conquest,       260),
        (ECombatRule/Destruction,    4),
    ]
    DefaultIncomeMultiplierIndex    = 4 // normal == 1, at index 4
    IncomeMultiplier = [ 0, 0.25, 0.5, 0.75, 1, 1.25, 1.5, 1.75, 2, 2.5, 3, 4, 5, 7.5, 10, 15, 20, 25, 50, 100, 999 ]
    TimeBeforeEarningCommandPointsSkirmish = MAP
    [
        (ECombatRule/NotSpecified,   60.0),
        (ECombatRule/Conquest,       60.0),
        (ECombatRule/Destruction,     4.0),
    ]
    TimeBeforeEarningCommandPointsStrategicBattleground = 60.0

    TimeBeforeEarningCommandPointsFactorToAddByNbPlayers = // Faktor der TimeBeforeEarningCommandPoints, der je nach Spielergrenzen hinzugefügt wird
                [
                    (10,    0.1), // ab 10 Spielern, 10% Verzögerung für das Einkommen
                    (20,    0.3)  // ab 20 Spielern, 30% Verzögerung für das Einkommen
                ]

//--------------------------- Zerstörungs-Modus Konstanten ----------------------------//

    DefaultIncomeMultiplierIndexInDestructionMode = 3 // mittel

    // Lokalisierungstoken für Einkommensstufen
    //                                            none         very_low     low         medium
    IncomeMultiplierTokensInDestructionMode = [ 'CONQ_NONE', 'CONQ_VLOW', 'CONQ_LOW', 'CONQ_MED', 'CONQ_MED', 'CONQ_MED', 'CONQ_MED', 'CONQ_MED', 'CONQ_MED', 'CONQ_MED', 'CONQ_MED', 'CONQ_MED', 'CONQ_MED', 'CONQ_MED']

    // Multiplicateur de points de commandement gagnes par joueur par période de TimeBeforeEarningCommandPoints en mode conquete
    //                                   none  very_low    low   medium
    IncomeMultiplierInDestructionMode = [  0,      0.5,   0.75,      1, 1.25, 1.5, 1.75, 2, 2.5, 3, 4, 5, 7.5, 10]

//------------------------- KI-Strategie Konstanten (Wargame) -------------------------//
    // Prozentualer Bonus auf das Einkommen der KI. Beispiel: 0.0 = +0%, 0.10 = +10%
    RelativeBonusFluxByIADifficulty = MAP
    [
        (IADifficulty/TresFacile,    0.0),
        (IADifficulty/Facile,        0.0),
        (IADifficulty/Normal,        0.0),
        (IADifficulty/Difficile,     0.0),
        (IADifficulty/TresDifficile, 0.5),
        (IADifficulty/PlusDifficile, 1.0),
    ]

    // Multiplikator der Anzahl von Einheiten im Deck der KI (z.B. 0.5 bedeutet 50% mehr Einheiten für die KI)
    DeckUnitCountMultiplierByIADifficulty = MAP
    [
        (IADifficulty/TresFacile,       0),
        (IADifficulty/Facile,           0),
        (IADifficulty/Normal,           0),
        (IADifficulty/Difficile,        0),
        (IADifficulty/TresDifficile,    0.5),
        (IADifficulty/PlusDifficile,    1.0),
    ]

    // Additiver XP-Bonus, der allen Einheiten im Deck der KI gegeben wird (z.B. 1 gibt allen +1 Level)
    DeckUnitExpLevelAdditiveModifierByIADifficulty = MAP
    [
        (IADifficulty/TresFacile,       -2),
        (IADifficulty/Facile,           -1),
        (IADifficulty/Normal,           0),
        (IADifficulty/Difficile,        0),
        (IADifficulty/TresDifficile,    0),
