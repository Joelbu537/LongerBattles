        private BANK_PCount_SmokeMul is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 1
        ),
        private BANK_PCount_SparksMul is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 1
        ),
        private BANK_PCount_SmokeStarterMul is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 1
        ),
    ]
    Actions =
    [
        export Fire_ALL is Simultaneous
        (
            Mobile = Template_MobileWithLocalRepereMatrixFactory
            (
                Position = float3[0.00, 0.00, 0.00]
