                InitialScale = BANK_ScaleFactor
                MaxScale = 1
                CentroidRelative = True
            )
            Actions =
            [
                export Feu1 is Template_ActionCall
                (
                    Action = ~/BANK_DarkFire_AD
                    NamedParameters = MAP[
                        ( 'Feu_Size_Mul', BANK_FLammeSizeMul * RandomRange[0.1, 0.2] ),
                        ( 'Duration', ~/BANK_DarkFireCompo/BANK_Lifetime ),
                        ( 'Ground_Size', ~/BANK_DarkFireCompo/BANK_Radius ),
                        ( 'PCount_FireMul', BANK_PCount_FireMul ),
                        ( 'PCount_SmokeMul', BANK_PCount_SmokeMul ),
                        ( 'PCount_SparksMul', BANK_PCount_SparksMul ),
                        ( 'PCount_SmokeStarterMul', BANK_PCount_SmokeStarterMul ),
                    ]
                ),
            ]
        ),
    ]
)

