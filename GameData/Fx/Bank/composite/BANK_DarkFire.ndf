export BANK_Test_DarkFire is Simultaneous
(
    Mobile = MobileUnCentroid()
    Actions =
    [
        export TestFireAC is Template_ActionCall
        (
            Action = ~/BANK_DarkFireCompo
            NamedParameters = MAP[
                ( 'BANK_Radius', RandomRange[1100, 1300]),
                ( 'BANK_Lifetime', 600 ),
                ( 'BANK_ScaleFactor', 1 ),
                ( 'BANK_FLammeSizeMul', RandomRange[2, 6] ),
                ( 'BANK_PCount_FireMul', RandomRange[0.33, 0.66] * $/VFX_Bank/FxLodLevel_from_05to1 ),
                ( 'BANK_PCount_SmokeMul', RandomRange[4, 8] * $/VFX_Bank/FxLodLevel_from_05to1 ),
                ( 'BANK_PCount_SparksMul', 0 ),
                ( 'BANK_PCount_SmokeStarterMul', RandomRange[1, 2] * $/VFX_Bank/FxLodLevel_from_05to1 ),
            ]

        ),
    ]
)

export BANK_DarkFireCompo is SimultaneousActionDeclaration
(
    Params =
    [
        private BANK_Radius is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 3000
        ),
        private BANK_Lifetime is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 120
        ),
        private BANK_ScaleFactor is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = RandomRange[0.75, 1.25] * 10
        ),
        private BANK_FLammeSizeMul is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = RandomRange[0.1, 0.2]
