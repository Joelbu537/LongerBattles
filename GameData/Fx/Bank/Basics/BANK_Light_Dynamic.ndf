// à utiliser seulement dans un SimultaneousActionDeclaration avec les paramètre d'un Dynamic_Flash
private template Dynamic_Flash_Spawner[] is ParticleBombSpawner
(
    ParticleMaxDurationForSpawnSkip = parDuration * 1.1
    Count = 1
    Spawner = ParticleSpawner
    (
        ParticleLifetime = parDuration
        Initialisers =
        [
            Initialiser_SetMobileWrapper(), // pour être utiliser par les clients pour calculer la position
            ParticleInitialiserList
            (
                Size = parSizeLBU * getX[ParticleMobileWrapperScale]
                ColorRGB = parColorStart
                Alpha = parAlpha
                Speed = parSpeed
                Position = parPosition
                CustomFloat_3 = parSizeLBU
                CustomFloat3_1 = parColorStart * RandomRange[0.75, 1]
                CustomFloat3_2 = parColorEnd * RandomRange[0.75, 1]
                CustomFloat3_3 = parPosition + SpawnerPosition
            ),
        ]
        ParticleDescriptor = ParticleDescriptor
        (
            RenderInfo = LightRenderInfo
            Evolvers = ParticleStandardEvolverList
            (
                ColorRGB = lerp[ParticleLifeRatio, ParticleCustomFloat3_1, ParticleCustomFloat3_2]
                Position = ParticleCustomFloat3_3 + ParticleElapsedTime * ParticleSpeed
                Size = ParticleCustomFloat_3 * getX[ParticleMobileWrapperScale]
            )
            ParticleRenderer =  $/VFX_Bank/PointLightRendererLBU
        )
    )
)

export BANK_Dynamic_Flash_Simple is ActionCallWithParameters
(
    Action = BANK_Dynamic_Flash
    Params =
    [
        public parSizeLBU       is Template_Param_Float  (),
        public parColorStart    is Template_Param_Float3 (),
        public parColorEnd      is Template_Param_Float3 (),
        public Position         is Template_Param_Float  (DefaultValue = float3[0,0,0]),
        public parDuration      is Template_Param_Float  (),
        public parOpacity       is Template_Param_Float  (),
    ]
    NamedParameters = MAP
    [
        ( 'parSizeLBU'          , parSizeLBU * RandomRange[0.8, 1.25] ),
        ( 'parColorStart'       , LinearColor[parColorStart] ),
        ( 'parColorEnd'         , LinearColor[parColorEnd] ),
        ( 'parPosition'         , Position ),
        ( 'parDuration'         , parDuration * RandomRange[0.8, 1.25] ),
        ( 'parAlpha'            , parOpacity ),
        ( 'parSpeed'            , float3[0.0, 0.0, 0.0] ),
    ]
)

// Only if you know that you don't need WithMultiLaunchSkip
export BANK_Dynamic_Flash is SimultaneousActionDeclaration
(
    Params =
    [
        public parSizeLBU           is Template_ActionAlias  ( ExpectedType = 'float'  DefaultValue = 32.5581395349),
        public parColorStart        is Template_ActionAlias  ( ExpectedType = 'float3' DefaultValue = LinearColor[0.6, 0.3, 0.1]),
        public parColorEnd          is Template_ActionAlias  ( ExpectedType = 'float3' DefaultValue = LinearColor[0.6, 0.3, 0.1]),
        public parPosition          is Template_ActionAlias  ( ExpectedType = 'float3' DefaultValue = float3[0, 0, 0]),
        public parDuration          is Template_ActionAlias  ( ExpectedType = 'float'  DefaultValue = 0.2),
        public parAlpha             is Template_ActionAlias  ( ExpectedType = 'float'  DefaultValue = 0.8),
        public parSpeed             is Template_Param_Float3 ( DefaultValue = float3[0, 0, 0] ),
    ]
    Actions =
    [
        Dynamic_Flash_Spawner(),
    ]
)

export BANK_Dynamic_Flash_Repeat_Simple is ActionCallWithParameters
(
    Action = BANK_Dynamic_Flash_Repeat
    Params =
    [
        public parSizeLBU       is Template_Param_Float  (),
        public parColorStart    is Template_Param_Float3 (),
        public parColorEnd      is Template_Param_Float3 (),
        public parHeight        is Template_Param_Float  (),
        public parDuration      is Template_Param_Float  (),
        public parOpacity       is Template_Param_Float  (),
        public parRepeatTime    is Template_Param_Float  (),
        public parRepeatCount   is Template_Param_Int    (),
        public parInitialDelay  is Template_Param_Float( DefaultValue = 0 ), //*
        public parFadeoutRatio  is Template_Param_Float (DefaultValue = 1.0),

    ]
    NamedParameters = MAP
    [
        ( 'parSizeLBU'          , parSizeLBU * RandomRange[0.8, 1.25] ),
        ( 'parColorStart'       , LinearColor[parColorStart] ),
        ( 'parColorEnd'         , LinearColor[parColorEnd] ),
        ( 'parPosition'         , GenFloat3[0.0, 0.0, parHeight] ),
        ( 'parDuration'         , parDuration * RandomRange[0.8, 1.25] ),
        ( 'parAlpha'            , parOpacity ),
        ( 'parSpeed'            , float3[0.0, 0.0, 0.0] ),
        ( 'RepeatTime'          , parRepeatTime ),
        ( 'RepeatCount'         , parRepeatCount ),
        ( 'parInitialDelay'     , parInitialDelay ), //*
        ( 'parFadeoutRatio'     , parFadeoutRatio ),

    ]
)

BANK_Dynamic_Flash_Repeat is SimultaneousActionDeclaration
(
    Params =
    [
        public parSizeLBU       is Template_Param_Float  ( DefaultValue = 32.5581395349),
        public parColorStart    is Template_Param_Float3 ( DefaultValue = LinearColor[0.6, 0.3, 0.1] ),
        public parColorEnd      is Template_Param_Float3 ( DefaultValue = LinearColor[0.6, 0.3, 0.1] ),
        public parPosition      is Template_Param_Float3 ( DefaultValue = float3[0, 0, 0] ),
        public parDuration      is Template_Param_Float  ( DefaultValue = 0.2 ),
        public parAlpha         is Template_Param_Float  ( DefaultValue = 0.8 ),
        public parSpeed         is Template_Param_Float3 ( DefaultValue = float3[0, 0, 0] ),
        public RepeatTime       is Template_Param_Float  ( DefaultValue = 0 ),
        public RepeatCount      is Template_Param_Float  ( DefaultValue = 0 ),
        public parInitialDelay  is Template_Param_Float  ( DefaultValue = 0 ), //*
        public parFadeoutRatio  is Template_Param_Float  ( DefaultValue = 1.0 ), //*

    ]
    Actions =
    [
    WaitInSec(Duration = parInitialDelay),

        TSimultaneousActionWithMultiLaunchLimit
        (
            RadiusForMultiLaunchSkip = parSizeLBU * 2 * GameUnitsPerLBU
            DurationForMultiLaunchSkip = RepeatTime == 0 ? parDuration : (RepeatCount == 0 ? 2 : RepeatTime * (RepeatCount - 0.9))
            MaxLaunchInRadius = 2
            Actions =
            [
                private Dynamic_Flash_Spawner is ParticleSpraySpawnerWithEvaluable
                (
                    Frequency = RepeatTime == 0 ? 0.5 : 1.0 div Max[RepeatTime, 0.001]
                    DurationInSec = RepeatTime == 0 ? parDuration : (RepeatCount == 0 ? 666 : RepeatTime * (RepeatCount - 0.9))
                    SpawnFirstParticleAtStart = true
                    InitialDelayInSec = parInitialDelay //*
                    PeriodInSec = RepeatTime
                    Spawner = ParticleSpawner
                    (
                        ParticleLifetime = parDuration
                        Initialisers =
                        [
                            ParticleInitialiserList
                            (
                                Size = 300
                                ColorModifier = float3[1, 1, 1]
                                Alpha = 1.0
                                ColorMultiplier = 1.0

                                CustomFloat_4 = parSizeLBU
                                CustomFloat_5 = parFadeoutRatio

                                ColorRGB = parColorStart

                                Speed = parSpeed
                                CustomFloat_1 = parAlpha //* 0.75
                                CustomFloat_2 = RandomRange[0.75, 1]
                                CustomFloat_3 = parDuration
                                CustomFloat3_1 = parColorStart * ParticleCustomFloat_2
                                CustomFloat3_2 = parColorEnd * ParticleCustomFloat_2
                                CustomFloat3_3 = parPosition + PositionUnScaled[MobilePosition, ParticleActionCentroid]
                            ),
                        ]
                        PostTransformInitialisers =
                        [
                            ParticleInitialiserList
                            (
                                Position = parPosition + SpawnerPosition
                            ),
                        ]
                        ParticleDescriptor = ParticleDescriptor
                        (
                            RenderInfo = LightRenderInfo
                            Evolvers = ParticleStandardEvolverList
                            (
                                Size = lerp[ParticleLifeRatio, ParticleCustomFloat_4, ParticleCustomFloat_4 * ParticleCustomFloat_5]//ParticleCustomFloat_1]//parAlpha]
                                ColorRGB = lerp[ParticleLifeRatio, ParticleCustomFloat3_1, ParticleCustomFloat3_2]
                                Position = ParticleCustomFloat3_3
                            )
                            ParticleRenderer = $/VFX_Bank/PointLightRendererLBU
                        )
                    )
                )
            ]
        ),
    ]
)

export BANK_Dynamic_Flash_Only_Two_Simple is ActionCallWithParameters
(
    Action = BANK_Dynamic_Flash_Only_Two
    Params =
    [
        public parSize          is Template_Param_Float  (),
        public parColorStart    is Template_Param_Float3 (),
        public parColorEnd      is Template_Param_Float3 (),
        public parHeight        is Template_Param_Float  ( DefaultValue = 0 ),
        public parDuration      is Template_Param_Float  ( DefaultValue = 0 ),
        public parOpacity       is Template_Param_Float  (),
        public parSpeed         is Template_Param_Float3 ( DefaultValue = float3[0.0, 0.0, 0.0]),
        public Position         is Template_Param_Float3 ( DefaultValue = float3[0.0, 0.0, 0.0]),
        public parInitialDelay  is Template_Param_Float  ( DefaultValue = 0 ), //*

    ]
    NamedParameters = MAP
    [
        // Francis (21/6/24) parSize est en GameEngineUnits pour l'instant. Il faudrait le passer en LBU côté assets (patterns de FX) mais il y a un conflit a gérer avec les paramètres pinnables
        ( 'parSizeLBU'          , (parSize div GameUnitsPerLBU) * RandomRange[0.8, 1.25] ),
        ( 'parColorStart'       , LinearColor[parColorStart] ),
        ( 'parColorEnd'         , LinearColor[parColorEnd] ),
        ( 'parPosition'         , float3[0.0, 0.0, 0.0] ),
        ( 'parDuration'         , parDuration * RandomRange[0.8, 1.25] ),
        ( 'parAlpha'            , parOpacity ),
        ( 'parSpeed'            , parSpeed),
        ( 'parInitialDelay'     , parInitialDelay ), //*

    ]
)

export BANK_Dynamic_Flash_Only_Two is BANK_Dynamic_Flash_WithMultiLaunchSkip(Count = 2)

// permet de limiter le nombre de light dans les fx qui spam à mort.
template BANK_Dynamic_Flash_WithMultiLaunchSkip
[
    Count
] is SimultaneousActionDeclaration
(
    Params =
    [
        public parSizeLBU    is Template_Param_Float  ( DefaultValue = 32.5581395349 ),
        public parColorStart is Template_Param_Float3 ( DefaultValue = LinearColor[0.6, 0.3, 0.1] ),
        public parColorEnd   is Template_Param_Float3 ( DefaultValue = LinearColor[0.6, 0.3, 0.1] ),
        public parPosition   is Template_Param_Float3 ( DefaultValue = float3[0, 0, 0] ),
        public parDuration   is Template_Param_Float  ( DefaultValue = 0.2 ),
        public parAlpha      is Template_Param_Float  ( DefaultValue = 0.8 ),
        public parSpeed      is Template_Param_Float3 ( DefaultValue = float3[0, 0, 0] ),
        public parInitialDelay  is Template_Param_Float  ( DefaultValue = 0 ), //*

    ]
    Actions =
    [
        WaitInSec(Duration = parInitialDelay),

        TSimultaneousActionWithMultiLaunchLimit
        (
            RadiusForMultiLaunchSkip = parSizeLBU * GameUnitsPerLBU * getX[MobileWrapperScale[MobileWrapper]]
            DurationForMultiLaunchSkip = parDuration
            MaxLaunchInRadius = <Count>
            Actions =
            [
                Dynamic_Flash_Spawner(),
            ]
        ),
    ]
)

export BANK_Light_Fade_Simple is ActionCallWithParameters
(
    Action = BANK_Light_Fade
    Params =
    [
        public parSizeLBU       is Template_Param_Float  (),
        public parColor         is Template_Param_Float3 (),
        public parHeight        is Template_Param_Float  (),
        public parDuration      is Template_Param_Float  (DefaultValue = 0),
        public parOpacity       is Template_Param_Float  (),
        public parDurationRatio is Template_Param_Float  (DefaultValue = 1),
    ]
    NamedParameters = MAP
    [
        ( 'parSizeLBU'          , parSizeLBU * RandomRange[0.8, 1.25]),
        ( 'parColor'            , parColor ),
        ( 'parPosition'         , GenFloat3[0.0, 0.0, parHeight] ),
        ( 'parDuration'         , parDuration * RandomRange[0.8, 1.25]  * parDurationRatio),
        ( 'parAlpha'            , parOpacity ),
    ]
)

export BANK_Light_Follow_Mobile_Random_Flash_Infinite_Simple is ActionCallWithParameters
(
    Action = BANK_Light_Follow_Mobile_Random_Flash_Infinite
    Params =
    [
        public parSizeLBU       is Template_Param_Float  (DefaultValue = 0),
        public parColor         is Template_Param_Float3 (),
        public parHeight        is Template_Param_Float  (),
        public parOpacity       is Template_Param_Float  (),
    ]
    NamedParameters = MAP
    [
        ( 'parSizeLBU'          , parSizeLBU * RandomRange[0.8, 1.25] ),
        ( 'parColor'            , parColor ),
        ( 'parPosition'         , GenFloat3[0.0, 0.0, parHeight] ),
        ( 'parAlpha'            , parOpacity ),
