)

BANK_Light_Fade_Evolver is ParticleStandardEvolverList
(
    ColorRGB = ParticleCustomFloat3_2
    Position = ParticleMobileWrapperPositionUnScaled + ParticleCustomFloat3_1
)

BANK_Light_Fade is BANK_Light_Follow_Mobile
(
    Evolvers = BANK_Light_Fade_Evolver

    export Test is Template_ActionCall
    (
        Action = BANK_Light_Fade
        NamedParameters = MAP
        [
            ( 'parSizeLBU'  , 32.5581395349),
            ( 'parColor'    , float3[153, 76, 25] * 0.00392),
            ( 'parPosition' , float3[0.0, 0.0, 400]),
            ( 'parDuration' , 1.5),
            ( 'parAlpha'  , 1),
        ]
    )
)

BANK_Light_Follow_Mobile_Random_Flash_Evolver is ParticleStandardEvolverList
(
    ColorRGB = ParticleCustomFloat3_2 * RandomRange[0.5, 1.0]
    Position = ParticleMobileWrapperPositionUnScaled + normalized[ParticleMobileWrapperAxeX] * getX[ParticleCustomFloat3_1] + normalized[ParticleMobileWrapperAxeY] * getY[ParticleCustomFloat3_1] + normalized[ParticleMobileWrapperAxeZ] * getZ[ParticleCustomFloat3_1]
)

export BANK_Light_Follow_Mobile_Random_Flash is BANK_Light_Follow_Mobile
(
    Evolvers = BANK_Light_Follow_Mobile_Random_Flash_Evolver
)

BANK_Light_Follow_Mobile_Random_Flash_Infinite is BANK_Light_Follow_Mobile_Infinite
(
    Evolvers = BANK_Light_Follow_Mobile_Random_Flash_Evolver
)

export BANK_Light_Follow_Mobile_Blink_Fast is BANK_Light_Follow_Mobile_Infinite
(
    Evolvers = BANK_Light_Fade_Evolver
)

template BANK_Light_Follow_Mobile
[
    Evolvers = [],
]
is SimultaneousActionDeclaration
(
    Params =
    [
        public parSizeLBU   is Template_ActionAlias  ( ExpectedType = 'float'  DefaultValue = 32.5581395349),
        public parColor     is Template_ActionAlias  ( ExpectedType = 'float3' DefaultValue = LinearColor[0.6, 0.3, 0.1]),
        public parPosition  is Template_ActionAlias  ( ExpectedType = 'float3' DefaultValue = float3[0, 0, 0]),
        public parDuration  is Template_ActionAlias  ( ExpectedType = 'float'  DefaultValue = 0.2),
        public parAlpha     is Template_ActionAlias  ( ExpectedType = 'float'  DefaultValue = 0.8),
    ]
    Actions =
    [
        WaitInSec( Duration = parDuration),
        ParticleBombSpawner
        (
            ParticleMaxDurationForSpawnSkip = parDuration * 1.1
            Count = 1
            Spawner = ParticleSpawner
            (
                ParticleLifetime = parDuration == 0.0 ? 666 : parDuration
                Initialisers =
                [
                    Initialiser_SetMobileWrapper(),
                    ParticleInitialiserList
                    (
                        Size = parSizeLBU
                        ColorRGB = parColor
                        Alpha = parAlpha
                        Position = parPosition
                        CustomFloat3_1 = parPosition
                        CustomFloat3_2 = parColor
                    ),
                ]
                ParticleDescriptor = ParticleDescriptor
                (
                    RenderInfo = LightRenderInfo
                    Evolvers = <Evolvers>

                    ParticleRenderer =  $/VFX_Bank/PointLightRendererLBU
                )
            )
        ),
    ]
)

template BANK_Light_Follow_Mobile_Infinite
[
    Evolvers = [],
]
is SimultaneousActionDeclaration
(
    Params =
    [
        public parSizeLBU   is Template_ActionAlias  ( ExpectedType = 'float'  DefaultValue = 32.5581395349),
        public parColor     is Template_ActionAlias  ( ExpectedType = 'float3' DefaultValue = LinearColor[0.6, 0.3, 0.1]),
        public parPosition  is Template_ActionAlias  ( ExpectedType = 'float3' DefaultValue = float3[0, 0, 0]),
        public parAlpha     is Template_ActionAlias  ( ExpectedType = 'float'  DefaultValue = 0.8),
    ]
    Actions =
    [
        Template_WaitForEver(),
        ParticleBombSpawner
        (
            Count = 1
            Spawner = ParticleSpawner
            (
                ParticleLifetime = 666
                Initialisers =
                [
                    Initialiser_SetMobileWrapper(),
                    ParticleInitialiserList
                    (
                        Size = parSizeLBU
                        ColorRGB = parColor
                        Alpha = parAlpha
                        Position = parPosition
                        CustomFloat3_1 = parPosition
                        CustomFloat3_2 = parColor
                    ),
                ]
                ParticleDescriptor = ParticleDescriptor
                (
                    RenderInfo = LightRenderInfo
                    Evolvers = <Evolvers>

                    ParticleRenderer =  $/VFX_Bank/PointLightRendererLBU
                    InfiniteParticles = true
                )
            )
        ),
    ]
)
