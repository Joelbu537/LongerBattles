

export BANK_Rain is SimultaneousActionDeclaration
(
    export Test is TActionCall(Action = BANK_Rain)
    Params =
    [
        private parOpacity              is Template_Param_Float ( DefaultValue = 0.3 ),
        private parMaxZ                 is Template_Param_Float ( DefaultValue = 30000 ),
        private parParticleCountPerBox  is Template_Param_Float ( DefaultValue = 50 ),
        private parBoxSize              is Template_Param_Float ( DefaultValue = 215 * 25 ),
        private parWindFactor           is Template_Param_Float ( DefaultValue = 2 ),
        private parWindRandom           is Template_Param_Float ( DefaultValue = 5 ),
        private parHorizontalBoxCount   is Template_Param_Float ( DefaultValue = 5 ),
        private parVerticalBoxCount     is Template_Param_Float ( DefaultValue = 1 ),
        private parSpeed                is Template_Param_Float ( DefaultValue = 8600 ),
        private parColor                is Template_Param_Float3( DefaultValue = LinearColor[0.7, 0.7, 0.7] ),
        private parParticleSize         is Template_Param_Float ( DefaultValue = 4 ),
        private parParticleSstretching  is Template_Param_Float ( DefaultValue = 0.15 ),
    ]
    Actions =
    [
        Simultaneous
        (
            Actions =
            [
                ParticleBombSpawner
                (
                    Count = 1 // cette particule peut ?e tu?iolement par la mort du mobile.
                    Spawner = ParticleSpawner
                    (
                        ParticleLifetime = 666
                        Initialisers =
                        [
                            ParticleInitialiserList
                            (
                                Position = -SpawnerPosition
                                CustomFloat_1 = parOpacity
                                CustomFloat_2 = parMaxZ
                                CustomFloat_3 = parParticleCountPerBox
                                CustomFloat_4 = parBoxSize
                                CustomFloat_5 = parWindFactor
                                CustomFloat_6 = parWindRandom
                                CustomFloat_7 = parHorizontalBoxCount
                                CustomFloat_8 = parVerticalBoxCount
                                CustomFloat3_1 = GenFloat3[0,0,parSpeed]
                                CustomFloat3_2 = parColor
                                CustomFloat3_3 = GenFloat3[parBoxSize, parBoxSize, parBoxSize]
                            ),
                        ]
                        ParticleDescriptor = ParticleDescriptor
                        (
                            InfiniteParticles = true
                            ParticleRenderer = $/VFX_Bank/NullRenderer
                            RenderInfo = $/VFX_Bank/NullRenderInfo
                            Evolvers = ParticleStandardEvolverListWithPhysic
                            (
                                AdditionnalEvolvers =
                                [
                                    EvolverSpraySpawner
                                    (
                                        Frequency = ParticleCustomFloat_3
                                        MaxSpawnedParticleLifetime = 1
                                        Spawner = ParticleSpawner
                                        (
                                            ParticleLifetime = 1
                                            Initialisers =
                                            [
                                                ParticleInitialiserList
                                                (
                                                    ColorMultiplier = 1
                                                    ColorModifier = SpawningParticleCustomFloat3_2
                                                    EmissivePower = 1
                                                    CustomFloat_1 = SpawningParticleCustomFloat_1
                                                    CustomFloat_2 = SpawningParticleCustomFloat_4
                                                    CustomFloat_3 = SpawningParticleCustomFloat_2
                                                    CustomFloat3_1 = PositiveUnitRandomBoxVolume * ParticleCustomFloat_2
                                                    CustomFloat3_2 = ParticleCustomFloat3_1 - ParticleCustomFloat3_3
                                                    CustomFloat3_3 = (SpawningParticleCustomFloat_5 + SpawningParticleCustomFloat_6 * PositiveUnitRandomSphereVolume) * MapWind + SpawningParticleCustomFloat3_1
                                                    CustomFloat3_4 = float3[0,0,1]
                                                    Size = 4
                                                    //BoxSize = SpawningParticleCustomFloat3_3
                                                ),
                                            ]
                                            ParticleDescriptor = ParticleDescriptor
                                            (
                                                RenderInfo = ParticleRenderInfo
                                                (
                                                    TextureName = 'GameData:/Assets/2D/Fx/spot.png'
                                                    Calque = 'Particles'
                                                    SortTriangles = true
                                                    OpaqueParticle = true
                                                )
                                                Evolvers = ParticleStandardEvolverList
                                                (
                                                    Direction = normalized[ParticleCustomFloat3_4]
                                                    Stretching = length[ParticleCustomFloat3_4] * 0.15
                                                    Opacity = ParticleCustomFloat_1 * MapToLinearSmoothRect[ParticleLifeRatio, 0, 0.1, 0.9, 1]
                                                    CustomFloat3_4 = ParticleSpeed * EvolverDt - CameraDeltaPosition * 0.025
                                                    Position= Mod[lerp[ParticleLifeRatio, ParticleCustomFloat3_1, ParticleCustomFloat3_2] - CameraPosition, GenFloat3[ParticleCustomFloat_2, ParticleCustomFloat_2, ParticleCustomFloat_2]]
                                                    Speed = (ParticleCustomFloat3_1 - ParticleCustomFloat3_2)
                                                )
                                                ParticleRenderer = ParticleRendererPeriodicBox
                                                (
                                                    BoxSize = 9000
                                                    XYRepeat = 4
                                                    ZRepeat = 1
                                                )
                                            )
                                        )
                                    ),
                                ]
                            )
                        )
                    )
                ),
            ]
        )
    ]
)
