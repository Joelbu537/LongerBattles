// GameData:/Fx/Bank/Basics/AoA_BANK_WasteGroundDust.ndf
// Call Test_WasteGroundDust in FX Tester
// Dust induced by shock-waves

export Test_WasteGroundDust is Template_ActionCall
(
    Action = ~/BANK_WasteGroundDust
    NamedParameters = MAP[
        ( 'BANK_OffsetPos', float3[0.00, 0.00, 0.00] ),
        ( 'BANK_ParticleCount', 25 * $/VFX_Bank/FxLodLevel_from_05to1 ),
        ( 'BANK_ParticleLifetime', RandomRange[0.75, 1.25] *5 ),
        ( 'BANK_InitRGBcolor', LinearColor255[228, 195, 152] ),
        ( 'BANK_EndRGBcolor', LinearColor[0, 0, 0] ),
        ( 'BANK_InitPosition', float3[0.00, 0.00, 400.00]  ),
        ( 'BANK_InitRotation', 0.25 ),
        ( 'BANK_InitSpeed', MinusOneToOneRandomDisc * float3[2000,2000,0] ),
        ( 'BANK_AlphaMul', RandomRange[4, 5]  ),
        ( 'BANK_AlphaStartDecayValue', 0.1 ),
        ( 'BANK_FluidFriction', 1.5 ),
        ( 'BANK_AccelerationField', $/VFX_Bank/MapWind + float3[100.00, 0.00, 0.00] ),
        ( 'BANK_ParticleRotationFactor', RandomRange[0.5, 1.5]  ),
        ( 'BANK_ParticuleStartSize', 400 ),
        ( 'BANK_ParticuleEndSize', 1500 ),
        ( 'BANK_ParticuleScaleSizeFactor', RandomRange[0.5, 1.5] )
    ]
)

export BANK_WasteGroundDust_Simple is ActionCallWithParameters
(
    Action = BANK_WasteGroundDust
    Params =
    [
        private parCount                    is Template_Param_Int (),
        private parLifetime                 is Template_Param_Float (),
        private parStartColor               is Template_Param_Float3 (),
        private parEndColor                 is Template_Param_Float3 (),
        private parStartHeight              is Template_Param_Float (),
        private parRandomInitPosRadius      is Template_Param_Float (),
        private parStartRotation            is Template_Param_Float (),
        private parStartSpeed3D             is Template_Param_Float3 (),
        private parOpacity                  is Template_Param_Float (),
        private parAlphaStartDecayValue     is Template_Param_Float (),
        private parFluidFriction            is Template_Param_Float (),
        private parWindWeight               is Template_Param_Float (),
        private parRotationFactor           is Template_Param_Float (),
        private parStartSize                is Template_Param_Int (),
        private parEndSize                  is Template_Param_Int (),
        private parScaleSizeFactor          is Template_Param_Float (),
        private parInitialDelay  is Template_Param_Float  ( DefaultValue = 0 ), //*
       // private parCount  is Template_Param_Float  ( DefaultValue = 0 ), //*


    ]
    NamedParameters = MAP
    [
        ( 'BANK_OffsetPos'                  , float3[0.0, 0.0, 0.0] ),
        ( 'BANK_ParticleCount'              , parCount * $/VFX_Bank/FxLodLevel_from_05to1 ),
        ( 'BANK_ParticleLifetime'           , parLifetime * RandomRange[0.75, 1.25] ),
        ( 'BANK_InitRGBcolor'               , LinearColor[parStartColor] ),
        ( 'BANK_EndRGBcolor'                , LinearColor[parEndColor] ),
        ( 'BANK_InitPosition'               , parRandomInitPosRadius * MinusOneToOneRandomDisc + parStartHeight * float3[0.0, 0.0, 1.0]),
        ( 'BANK_InitRotation'               , parStartRotation ),
        ( 'BANK_InitSpeed'                  , ToFloat3[CosSin[HomogeneousUnit * PI2]] * parStartSpeed3D * RandomRange[0.0, 1] ),
        ( 'BANK_AlphaMul'                   , parOpacity * RandomRange[6, 8] ),
        ( 'BANK_AlphaStartDecayValue'       , parAlphaStartDecayValue),
        ( 'BANK_FluidFriction'              , parFluidFriction * RandomRange[0.8, 1.25] ),
        ( 'BANK_AccelerationField'          , parWindWeight * $/VFX_Bank/MapWind ),
        ( 'BANK_ParticleRotationFactor'     , parRotationFactor * RandomRange[0.5, 1.5]  ),
        ( 'BANK_ParticuleStartSize'         , parStartSize ),
        ( 'BANK_ParticuleEndSize'           , parEndSize ),
        ( 'BANK_ParticuleScaleSizeFactor'   , parScaleSizeFactor * RandomRange[0.5, 1.5] ),
        ( 'parInitialDelay'     , parInitialDelay ), //*
//        ( 'parCount'     , parInitialDelay ), //*


    ]
)
