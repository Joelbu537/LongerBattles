
SFX_Steelman_NATO_Combat_Air_Air_1 is TSoundDescriptor
(
    SoundSettings = $/SoundSettings/SoundSettings_Steelman_Combat
    TheSoundStream = TSoundStream(FileName = "GameData:/Assets/Sounds/SFX/Steelman/Steelman_Air_Combat_1.wav")
)

SFX_FireLoopSoundDescriptor is TSoundDescriptor
(
    SoundSettings = $/SoundSettings/SoundSettings_Impact_Balles
    TheSoundStream = TSoundStream (FileName = "GameData:/Assets/Sounds/SFX/Env/fire_loop.wav")
    UseSpecialLoop = true
)

export SFX_Steelman_Combat_Air_Air_Sound is TSoundSet(Items = [SFX_Steelman_NATO_Combat_Air_Air_1])
export FireLoopSoundSet is TSoundSet(Items = [SFX_FireLoopSoundDescriptor])

template SimpleSFX
[
    SoundSet : TSoundSet,
] is SimultaneousActionDeclaration
(
    Mobile = Template_MobileSoundSlotFactory()
    Actions =
    [
        TActionDescriptorAudio
        (
            SoundSet = <SoundSet>
        )
    ]
)

export SFXAction_FireLoop         is SimpleSFX(SoundSet = FireLoopSoundSet)
export SFXAction_Mortar_Impact    is SimpleSFX(SoundSet = $/GFX/Sound/Sound_ImpactMortier_moyenSol)
export SFXAction_Artillery_Impact is SimpleSFX(SoundSet = $/GFX/Sound/Sound_ImpactArtillerie_lourdeSol)
export SFXAction_Mega_Bomb_Impact is SimpleSFX(SoundSet = $/GFX/Sound/Sound_FULDA_Bombe_Mk84_sol)
export SFXAction_Bomb_Impact      is SimpleSFX(SoundSet = $/GFX/Sound/Sound_FULDA_Bombe_Mk_sol)

