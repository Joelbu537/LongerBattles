// GameData:/Fx/Bank/Basics/AoA_BANK_Ground_Projection.ndf
// Call Test_Ground_Projection in FX Tester
// Ground mud projection from blast

export Test_Conic_Ground_Projection is Simultaneous
(
    Mobile = MobileUnCentroid()
    Actions =
    [
        Template_ActionCall
        (
            Action = Conic_Ground_Projection
            NamedParameters = MAP[
                ( 'parSize', 2500 * RandomRange[0.5, 1] ),
                ( 'parCount', 10 ),
                ( 'parDuration', 1.5 * RandomRange[0.5, 1.5] ),
            ]
        ),
        WaitInSec
        (
            Duration = 5
        )
    ]
)

export Conic_Ground_Projection_Simple is ActionCallWithParameters
(
    Action = Conic_Ground_Projection
    Params =
    [
        private parSize         is Template_Param_Float (),
        private parCount        is Template_Param_Int (),
        private parDuration     is Template_Param_Float (),
        private parColor        is Template_Param_Float3 (),
    ]
    NamedParameters = MAP
    [
        ( 'parSize'             , parSize * RandomRange[0.8, 1.2] ),
        ( 'parCount'            , parCount ),
        ( 'parDuration'         , parDuration * RandomRange[0.8, 1.2] ),
        ( 'parColor'            , LinearColor[parColor] ),
    ]
)

export Conic_Ground_Projection is SimultaneousActionDeclaration
(
    Params =
    [
        private parSize is Template_Param_Float (),
        private parCount is Template_Param_Float (),
        private parDuration is Template_Param_Float (),
        private parColor is Template_Param_Float3 ( DefaultValue = LinearColor255[255, 255, 255] )
    ]
    Actions =
    [
        private SmallMudExplosion is ParticleBombSpawner
        (
            Count = parCount
            Spawner = ParticleSpawner
            (
                ParticleLifetime = parDuration * RandomRange[0.5, 1.5]
                Initialisers =
                [
                    ParticleInitialiserList
                    (
                        ColorModifier = float3[1, 1, 1]

                        Position = ParticleSpeed * 0.05
                        Size = parSize * RandomRange[0.4,0.6]
                        Opacity = 1
                        Rotation = RandomRange[0.0, 3.14]
                        RotationSpeed = 360
                        //Direction = NarrowRandomValue[MinusOneToOneRandomHemisphereSurface, -0.3]
                        CustomFloat_1 = ParticleOpacity
                        CustomFloat_2 = parSize
                        CustomFloat3_1 = SpawnerPosition
                        Speed = NarrowRandomValue[MinusOneToOneRandomHemisphereVolume, 2] * parSize * 1.5
                        EmissivePower = 1
                        Alpha = 1
                    ),
                    Initialiser_TextureSmallIndex
                    (
                        InitFunction = SmallMudTextures[RandomUnit]
                    ),
                ]
                ParticleDescriptor = ParticleDescriptor
                (
                    RenderInfo = DeferredParticleRenderInfo
                    (
                        TextureName = 'GameData:/Assets/2D/Fx/fx_trail.png'
                    )
                    ParticleRenderer = $/VFX_Bank/LitParticleRenderer
                    Evolvers = ParticleStandardEvolverListWithPhysic
                    (
                        FluidFriction = 0.2
                        PhysicAccelerationField = GenFloat3[0, 0, -2000]
                        Opacity = ParticleCustomFloat_1 * Decay[ParticleLifeRatio, 0.7]// * (1-abs[dot[CameraDirection, ParticleDirection]])
                    )
                )
            )
        ),
    ]
)

export BigMudTextures is Template_EvaluableTable
(
    Values =
    [
        TConstantTexture (TextureName = 'GameData:/Assets/2D/Fx/fx_terre_00_v2.png' ),
        TConstantTexture (TextureName = 'GameData:/Assets/2D/Fx/fx_terre_01_v2.png' ),
    ]
)

private SmallMudTextures is Template_EvaluableTable
(
    Values =
    [
        TConstantTexture (TextureName = 'GameData:/Assets/2D/Fx/fx_terre_02_v2.png' ),
        TConstantTexture (TextureName = 'GameData:/Assets/2D/Fx/fx_terre_03.png' ),
    ]
)

