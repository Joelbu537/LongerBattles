export BANK_Rebond_Obus_Simple is ActionCallWithParameters
(
    Action = BANK_Rebond_Obus
    Params =
    [
        private Gravity                         is Template_Param_Float3  ( DefaultValue = 200 ),
        private Dir                              is Template_Param_Float3  ( DefaultValue = float3[1000, 0, 0] ),
        private parOpacity                      is Template_Param_Float  ( DefaultValue = 0 ),
        private parColor                        is Template_Param_Float3 ( DefaultValue = float3[1, 1, 1] ),
        private parEmissivePowerScale           is Template_Param_Float  ( DefaultValue = 1.0 ),
        private parSizeScale                    is Template_Param_Float ( DefaultValue = 1 ),
        private parDurationInSec                   is Template_Param_Float (),
        private parPinPower                     is Template_Param_Float ( DefaultValue = 1 ),
        private InitialSpeed                    is Template_Param_Float3( DefaultValue = float3[1000, 0, 0] ),
        private FadeDurationAfterHit            is Template_Param_Float ( DefaultValue = 1 ),
    ]
    NamedParameters = MAP
    [
        ( 'Gravity'                             , Gravity),
        ( 'parOpacity'                          , parOpacity == 0.0 ? 1.0 : parOpacity),
        ( 'parColor'                            , LinearColor[parColor]),
        ( 'parEmissivePowerScale'               , parEmissivePowerScale * 0.1),
        ( 'parSizeScale'                        , parSizeScale),
        ( 'parFlyDuration'                      , parDurationInSec),
        ( 'parPower'                            , parPinPower),
        ( 'parInitialSpeed'                     , InitialSpeed),
        ( 'Dir'                                 , Dir),
        ( 'FadeDurationAfterHit'                , FadeDurationAfterHit),
    ]
)

export BANK_Rebond_Obus is SimultaneousActionDeclaration
(
    Params =
    [
        private Gravity                         is Template_Param_Float3 ( DefaultValue = 200 ),
        private Dir                              is Template_Param_Float3 ( DefaultValue = float3[1000, 0, 1000] ),
        private parOpacity                      is Template_Param_Float ( DefaultValue = 0 ),
        private parColor                        is Template_Param_Float3( DefaultValue = float3[1, 1, 1] ),
        private parEmissivePowerScale           is Template_Param_Float ( DefaultValue = 1 ),
        private parSizeScale                    is Template_Param_Float ( DefaultValue = 1 ),
        private parFlyDuration                  is Template_Param_Float ( DefaultValue = 1 ),
        private parPower                        is Template_Param_Float ( DefaultValue = 1 ),
        private parInitialSpeed                 is Template_Param_Float3( DefaultValue = float3[1000, 0, 0] ),
        private FadeDurationAfterHit            is Template_Param_Float ( DefaultValue = 1),
    ]
    LocalVariables =
    [
        public FlyingTime is Template_Pinnable
        (
            InitialValue = parFlyDuration
            ExpectedType = 'float'
        ),
        public LocalColor is Template_Pinnable
        (
            InitialValue = parColor
            ExpectedType = 'float3'
        ),
    ]
    Actions =
    [
        public Projectile_Trail is ParticleBombSpawner
        (
            ParticleMaxDurationForSpawnSkip = (FlyingTime) * 1.1
            Count = 1
            Spawner = ParticleSpawner
            (
                ParticleLifetime = FlyingTime
                Initialisers =
                [
                    Initialiser_CreateTrailId( OverrideValueFromSpawner = False ), // pour pouvoir avoir une trail derrière.
                    Initialiser_SetMobileWrapper(), // pour pouvoir suivre le mobile.
                    ParticleInitialiserList
                    (
                        Size = 300
                        Alpha = 1.0

                        CustomFloat_1 = FlyingTime
                        CustomFloat_2 = parSizeScale
                        CustomFloat_3 = Gravity
                        CustomFloat_4 = FadeDurationAfterHit
                        CustomFloat_5 = parSizeScale
                        EmissivePower = parEmissivePowerScale * 0.5
                        CustomFloat_7 = parOpacity * 0.8
                        CustomFloat_9 = 1
                        Opacity = 0
                        ColorModifier = LocalColor
                        CustomFloat3_1 = ParticleCustomFloat3_3
                        // position initiale
                        CustomFloat3_2 = MobilePosition
                        Speed = ParticleCustomFloat3_3
                        CustomFloat3_3 = float3[0,0,7500] + OrientAndNarrowRandomValue[MinusOneToOneRandomHemisphereSurface , Dir , 2] * RandomRange[35000, 60000]
                    )
                ]
                ParticleDescriptor = ParticleDescriptor
                (
                    RenderInfo = ParticleRenderInfo
                    (
                        ZTest = True
                        ZWrite = False
                        SortTriangles = true
                        TextureName = 'GameData:/Assets/2D/Fx/reactor.png'
                        Calque = 'Particles'
                        EmissiveParticle = True
                    )
                    ParticleRenderer = $/VFX_Bank/LitParticleRendererNoCentroidPositioning
                    Evolvers = Template_List
                    (
                        Evolvers =
                        [
                            ParticleStandardEvolverListWithPhysic
                            (
                                Direction = ParticleSpeed
                                FluidFriction = 1
                                OffsetAlongDirection = (- ($/VFX_Bank/ParticleSize * $/VFX_Bank/ParticleStretching) div 2.0)
                                PhysicAccelerationField = float3[0.00, 0.00, -20000.00]
                                Stretching = 2
                                Alpha = ParticleCustomFloat_7
                                Size = ParticleCustomFloat_5 * ( 200 )
                                CustomFloat_6 = sat[length[ParticleSpeed]  * 0.0001]
                            ),
                            TrailSpawner
                            (
                                DistanceBetweenSpawn = (0.01 + 10 * ParticleCustomFloat_6 * ParticleCustomFloat_6)
                                Spawner = ParticleSpawner
                                (
                                    ParticleLifetime = SpawningParticleCustomFloat_4 + SpawnerRemainingLifeRatio * SpawningParticleDuration
                                    Initialisers =
                                    [
                                        ParticleInitialiserList
                                        (
                                            Size = 300
                                            ColorModifier = float3[1, 1, 1]
                                            Alpha = 1.0

                                            ColorMultiplier = ParticleCustomFloat_2 > 5.5 ? 5 : 2
                                            ColorRGB = $/VFX_Bank/SpawningParticleColorModifier
                                            CustomFloat_1 = $/VFX_Bank/SpawningParticleAlpha * MapToLinearSmoothRect[SpawningParticleElapsedTime, 0, SpawningParticleDuration * 0.03,SpawningParticleDuration ,SpawningParticleDuration * 1.5] //* Decay[SpawningParticleLifeRatio, 1]
                                            CustomFloat_2 = $/VFX_Bank/SpawningParticleCustomFloat_2
                                            CustomFloat_3 = SpawnerRemainingLifeRatio * SpawningParticleDuration
                                            CustomFloat_4 = SpawningParticleCustomFloat_4 + ParticleCustomFloat_3
                                            Opacity = 1
                                        )
                                    ]
                                    ParticleDescriptor = ParticleDescriptor
                                    (
                                        RenderInfo = ParticleRenderInfo
                                        (
                                            ZTest = True
                                            ZWrite = False
                                            SortTriangles = True
                                            TextureName = 'GameData:/Assets/2D/Fx/trail_nuage_strip_32_02.png'
                                            Calque = 'Last'
                                            OpaqueParticle = True
                                        )
                                        Evolvers = ParticleStandardEvolverList
                                        (
                                            TexCoordU = $/VFX_Bank/ParticleCurvilinearAbscissa div 8000
                                            ColorRGB  = lerp[(ParticleCustomFloat_2 > 5.5 ? 0 : $/VFX_Bank/ParticleLifeRatio), $/VFX_Bank/ParticleColorRGB, float3[1, 1, 1]]
                                            Alpha     = (1-MapToLinearSmoothStep[ParticleElapsedTime, ParticleCustomFloat_3, ParticleCustomFloat_4]) * ParticleCustomFloat_1 * MapToLinearSmoothStep[ParticleCurvilinearAbscissa, 0, 30]
                                            Size      = ( 200 * $/VFX_Bank/ParticleCustomFloat_2 )
                                        )
                                        ParticleRenderer = ParticleRendererMeshTrail ( ScalingMode = 1 )
                                    )
                                )
                            ),
                        ]
                    )
                )
            )
        ),
        WaitInSec(Duration = FlyingTime + FadeDurationAfterHit),
    ]
)
