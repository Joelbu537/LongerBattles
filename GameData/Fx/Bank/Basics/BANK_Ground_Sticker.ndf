template template_BANK_Ground_Sticker
[
    NoSkip  = false,
    TextureName                = 'GameData:/Assets/2D/Stikers_Impact/ImpactClusterBomb_01.png',
    NormalMap                  = 'GameData:/Assets/2D/Stikers_Impact/ImpactClusterBomb_01_NM.png',
    ORSMap                     = 'VirtualData:/ToutJaune',

    SeparateAlphaTexture = '',

    DisplacementAmplitudeLBU,
    SizeMultiplier = 1,
    DisplacementMapZero = 1,
    Calque = 'Top',
    MinimalFxPreset = $/GraphicOption/FxPresetVeryLow,
    MaxParticleCount = 400
] is SimultaneousActionDeclaration
(
    Params =
    [
        public BANK_position    is Template_Param_Float3 (DefaultValue = float3[0.00, 0.00, 0.00]),
        public BANK_size        is Template_Param_Float  (DefaultValue = 1000),
        public BANK_lifetime    is Template_ActionAlias  (DefaultValue = 10),
        public BANK_color       is Template_Param_Float3 (DefaultValue = LinearColor[1.00, 1.00, 1.00]),
        public Bank_FadeInTime  is Template_Param_Float  (DefaultValue = 0.25),
    ]
    LocalVariables =
    [
        DurationUnRandomized is Template_Pinnable (ExpectedType = 'float' InitialValue = 9090)
    ]
    private Bomb_Sticker is ParticleBombSpawner
    (
        ParticleMaxDurationForSpawnSkip = DurationUnRandomized
        Count = 1
        Position = BANK_position
        Spawner = private Spawner is ParticleSpawner
        (
            ParticleLifetime = DurationUnRandomized * RandomRange[ 0.9, 1.1 ]
            ParticleDescriptor = ParticleDescriptor
            (
                RenderInfo =  ParticleRenderInfoSticker
                (
                    TextureName = <TextureName>
                    NormalMap = <NormalMap>
                    ORSMap = <ORSMap>
                    SeparateAlphaTexture = <SeparateAlphaTexture>

                    DisplacementAmplitudeLBU = <DisplacementAmplitudeLBU>
                    DisplacementMapZero = <DisplacementMapZero>

                    Calque = <Calque>

                    MinimalFxPreset = <MinimalFxPreset>
                    MaxParticleCount = <MaxParticleCount>
                )
                Evolvers = ParticleStandardEvolverList
                (
                    Alpha = Attack[ParticleElapsedTime, 0.1] * Decay[ParticleLifeRatio, 0.99]
                    UseHardCodedRotation = false
                )
                ParticleRenderer = $/VFX_Bank/RealSticker
                InfiniteParticles = False
            )
            Initialisers =
            [
                ParticleInitialiserList
                (
                    ColorModifier = float3[1, 1, 1]

                    Size = <SizeMultiplier> *  BANK_size
                    ColorRGB = BANK_color
                    Alpha = 1
                    ColorMultiplier = 1
                    Rotation = $/VFX_Bank/RandomUnit
                    CustomFloat_2 = Bank_FadeInTime + 0.01
                    Position = float3[0,0,0]
                ),
            ]

        )
    )

    Actions =
    ( <NoSkip> ?
    [
    Bomb_Sticker
    ] :
    [
        private SkipMultiLaunch is TSimultaneousActionWithMultiLaunchLimit
        (
            RadiusForMultiLaunchSkip     = BANK_size * 0.15 // uniquement pour filtrer des impacts a peu pres au même endroit.
            DurationForMultiLaunchSkip   = 3
            MaxLaunchInFrame  = 50
            MaxLaunchInRadius = 1
            Actions =
            [
            Bomb_Sticker
            ]
        )
    ]
    )
    MaxDuration = 60
)
