export Test_BANK_Ground_Sticker is Simultaneous
(
    Mobile = MobileUnCentroid()
    Actions =
    [
        Template_ActionCall
        (
            Action = BANK_Ground_Sticker
            NamedParameters = MAP[
                ( 'BANK_position'       , float3[0.0, 0.0, 0.0] ),
                ( 'BANK_size'           , 1000 * RandomRange[0.8, 1.25]),
                ( 'BANK_lifetime'       , 10 ),
                ( 'BANK_color'          , float3[1.0, 1.0, 1.0] ),
                ( 'Bank_FadeInTime'     , 0.25 * RandomRange[0.9, 1.1]),
            ]
        ),
    ]
)

export BANK_Ground_Sticker_Simple is Template_BANK_Ground_Sticker_Simple ( Sticker = BANK_Ground_Sticker )
export BANK_Ground_Sticker_impact_explo is Template_BANK_Ground_Sticker_Simple ( Sticker = BANK_Ground_Sticker_impact )
export BANK_Ground_Sticker_Big_Simple is Template_BANK_Ground_Sticker_Simple ( Sticker = BANK_Ground_Sticker_Big )
export BANK_Ground_Sticker_Burned_Simple is Template_BANK_Ground_Sticker_Simple ( Sticker = BANK_Ground_Sticker_Burned )
export BANK_Ground_Sticker_destruction_Simple is Template_BANK_Ground_Sticker_Simple ( Sticker = BANK_Ground_Sticker_destruction )
export BANK_Ground_Sticker_Burned_No_Displace_Simple is Template_BANK_Ground_Sticker_Simple ( Sticker = BANK_Ground_Sticker_Burned_No_Displace )

template Template_BANK_Ground_Sticker_Simple
[
    Sticker = ''
] is ActionCallWithParameters
(
    Action = <Sticker>
    Params =
    [
        private parDeltaPosition is Template_Param_Float (),
        private parSize          is Template_Param_Float (),
        private parLifetime      is Template_Param_Float (),
        private parColor         is Template_Param_Float3 (),
        private parFadeInTime    is Template_Param_Float (),
    ]
    NamedParameters = MAP
    [
        ( 'BANK_position'       , parDeltaPosition * MinusOneToOneRandomDisc ),
        ( 'BANK_size'           , parSize * RandomRange[0.9, 1.1]),
        ( 'BANK_lifetime'       , parLifetime * RandomRange[0.8, 1.2] * $/VFX_Bank/FxLodLevel_from_05to1 ),
        ( 'BANK_color'          , LinearColor[parColor] ),
        ( 'Bank_FadeInTime'     , parFadeInTime * RandomRange[0.9, 1.1]),
    ]
)

export BANK_Ground_Sticker is template_BANK_Ground_Sticker
(
    TextureName                = 'GameData:/Assets/2D/Stikers_Impact/Impact_Big_01.png'
    NormalMap                  = 'GameData:/Assets/2D/Stikers_Impact/Impact_Big_01_P.png'
    SeparateAlphaTexture       = 'GameData:/Assets/2D/Stikers_Impact/Impact_Big_01_A.png'
    ORSMap                     = 'GameData:/Assets/2D/Stikers_Impact/Impact_Big_01_ORS.png'

    DisplacementAmplitudeLBU = 0.05 // 0.1
    SizeMultiplier =  0.5
    DisplacementMapZero = 0.8 //0.8
    Calque = 'Bottom'
    MinimalFxPreset = $/GraphicOption/FxPresetLow
)
