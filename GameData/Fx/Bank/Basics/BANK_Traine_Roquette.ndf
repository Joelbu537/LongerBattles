
export BANK_Traine_Roquette_Simple is Template_ActionWithParameters
(
    Params =
    [
        private RocketMeshId    is Template_Param_Int  ( DefaultValue = 0 ),
        private RocketScale     is Template_Param_Float  ( DefaultValue = 1 ),
        private parPinPower     is Template_Param_Int ( DefaultValue = 0 ),
        private DurationInSec   is Template_Param_Int ( DefaultValue = 10),
        private parSFXId        is Template_Param_Int ( DefaultValue = 0 ),
    ]
    Action = TActionDescriptor_Select
    (
        Index = RocketMeshId + 1
        Actions = Roquette_Meshs_List.Value
    )
)

template Template_CallRoquette
[
    Mesh,
] is Template_ActionCall
(
    Action = Template_TraineRoquette(Mesh = Template_MeshResourcesForFxEditor(Value = <Mesh>))
    NamedParameters = MAP
    [
        ( 'RocketMeshId'    , BANK_Traine_Roquette_Simple/RocketMeshId ),
        ( 'RocketScale'     , BANK_Traine_Roquette_Simple/RocketScale ),
        ( 'parPower'        , BANK_Traine_Roquette_Simple/parPinPower ),
        ( 'parFlyDuration'  , BANK_Traine_Roquette_Simple/DurationInSec ),
        ( 'parSFXId'        , BANK_Traine_Roquette_Simple/parSFXId ),
    ]
)

