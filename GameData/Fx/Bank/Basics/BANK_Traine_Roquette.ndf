template Template_TraineRoquette
[
    Mesh,
]
is SimultaneousActionDeclaration
(
    Params =
    [
        private RocketMeshId    is Template_Param_Int  (DefaultValue = 0),
        private RocketScale     is Template_Param_Float(DefaultValue = 1),
        private parPower        is Template_Param_Int  (DefaultValue = 0),
        private parFlyDuration  is Template_Param_Int  (DefaultValue = 0),
        private parSFXId        is Template_Param_Int  (DefaultValue = 0),
    ]
    Mobile = MobileUnCentroid()
    Actions =
    [
        TWaitInSec( Duration = parFlyDuration ),
        private Projectile_Mesh is ParticleBombSpawner
        (
            ParticleMaxDurationForSpawnSkip = parFlyDuration * 1.1
            Count = 1
            Spawner = ParticleSpawner
            (
                ParticleLifetime = parFlyDuration
                Initialisers =
                [
                    Initialiser_SetMobileWrapper(),
                    ParticleInitialiserList
                    (
                        ScaleForMesh = RocketScale
                        Size = RocketScale
                        DynamicMesh = <Mesh>
                        Direction = normalized[ParticleMobileWrapperAxeX]
                    )
                ]
                ParticleDescriptor = ParticleDescriptor
                (
                    RenderInfo = ShadowedParticleMeshRenderInfo
                    Evolvers = ParticleStandardEvolverList
                    (
                        Position = ParticleMobileWrapperPositionUnScaled
                        Direction = normalized[ParticleMobileWrapperAxeX]
                        RotationAxisForMesh = float3[0.00, 1.00, 0.00]
                        Alpha = 1
                    )
                    ParticleRenderer = Template_ParticleRendererDynamicMesh
                    (
                        AuthorizedMeshes = [<Mesh>]
                    )
                )
            )
        ),
        Competition
        (
            Mobile = Template_MobileSoundSlotFactory()
            Actions =
            [
                WaitInSec( Duration = parFlyDuration),
                Template_Select
                (
                    Actions = [
                        Aucun is WaitInSec(Duration = 0),
                        Petit is Template_SFX_Propulsion_x3
                        (
                            SoundFile1 = 'GameData:/Assets/Sounds/SFX/Missiles/Traine_Missile_Petit_01.wav'
                            SoundFile2 = 'GameData:/Assets/Sounds/SFX/Missiles/Traine_Missile_Petit_02.wav'
                            SoundFile3 = 'GameData:/Assets/Sounds/SFX/Missiles/Traine_Missile_Petit_03.wav'
                            SoundSettings_Default = $/SoundSettings/SoundSettings_Propulsion_Missile_Petit
                        ),
                        Moyen is Template_SFX_Propulsion_x3
                        (
                            SoundFile1 = 'GameData:/Assets/Sounds/SFX/Missiles/Traine_Missile_Moyen_01.wav'
                            SoundFile2 = 'GameData:/Assets/Sounds/SFX/Missiles/Traine_Missile_Moyen_02.wav'
                            SoundFile3 = 'GameData:/Assets/Sounds/SFX/Missiles/Traine_Missile_Moyen_03.wav'
                            SoundSettings_Default = $/SoundSettings/SoundSettings_Propulsion_Missile_Moyen
                        ),
                        Gros is Template_SFX_Propulsion_x3
                        (
                            SoundFile1 = 'GameData:/Assets/Sounds/SFX/Missiles/Traine_Missile_Gros_01.wav'
                            SoundFile2 = 'GameData:/Assets/Sounds/SFX/Missiles/Traine_Missile_Gros_02.wav'
                            SoundFile3 = 'GameData:/Assets/Sounds/SFX/Missiles/Traine_Missile_Gros_03.wav'
                            SoundSettings_Default = $/SoundSettings/SoundSettings_Propulsion_Missile_Gros
                        ),
                    ]
                    Index = parSFXId + 1
                )
            ]
        )
    ]
)

export Propulsion_Roquette_Sfx_List is TEugBListPBaseClass
(
    Value =
    [
        public Aucun is TConstant( Value = '' ),
        public Petit is TConstant( Value = '' ),
        public Moyen is TConstant( Value = '' ),
        public Gros  is TConstant( Value = '' ),
    ]
)
