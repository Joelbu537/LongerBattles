export BANK_Rubble2_test is Simultaneous
(
    Mobile = Template_MobileWithLocalRepereMatrixFactory
    (
        Position = float3[0.00, 0.00, 1000.00]
        DoNotInheritCentroid = true
        IntroduceCentroid = False
        CentroidRelative = False
        UsePreviousMobileAsCenterOfScale = False
    )
    Actions =
    [
        private BANK_Rubble2_AC_test is Template_ActionCall
        (
            Action = ~/BANK_Bomblet_Simple
            NamedParameters = MAP[
                ( 'parDispersion', 500),
                ( 'parCountDebrits', 10 ),
                ( 'parSpeed', $/VFX_Bank/MinusOneToOneRandomHemisphereVolume * 5000 ),
                ( 'parLifetime', 4 ),
                ( 'parDebritSizeMul', 2 ),
                ( 'parDir', float3[1,0,0]),
                ( 'parNarrowness', 1),
            ]
        ),
    ]
)
template RubbleSelect_List
[
    Params,
] is TEugBListPBaseClass
(
    Value =
    [
        Template_ActionCall
        (
            Action = BANK_Rubble_Updated
            NamedParameters = <Params> +
            MAP[( 'BANK_Mesh_Distribution'          , mesh_rubble_unit[$/VFX_Bank/RandomUnit]),]
        ),
        Template_ActionCall
        (
            Action = BANK_Rubble2
            NamedParameters = <Params> +
            MAP[( 'BANK_Mesh_Distribution'          , mesh_rubble_building[$/VFX_Bank/RandomUnit]),]
        ),
        Template_ActionCall
        (
            Action = BANK_Rubble2
            NamedParameters = <Params> +
            MAP[( 'BANK_Mesh_Distribution'          , mesh_rubble_forest[$/VFX_Bank/RandomUnit]),]
        ),
        Template_ActionCall
        (
            Action = BANK_Rubble2
            NamedParameters = <Params> +
            MAP[( 'BANK_Mesh_Distribution'          , mesh_rubble_wood[$/VFX_Bank/RandomUnit]),]
        ),
        Template_ActionCall
        (
            Action = BANK_Rubble_Updated
            NamedParameters = <Params> +
            MAP[( 'BANK_Mesh_Distribution'          , mesh_rubble_avion[$/VFX_Bank/RandomUnit]),]
        ),
    ]
)


export BANK_Rubble2_Simple is Template_ActionWithParameters
(
    Params =
    [
        private parLifetime                 is Template_Param_Float(),
        private parDispersion               is Template_Param_Float(),
        private parSpeed                    is Template_Param_Float3(),
        private parMinSpeedRatio            is Template_Param_Float( DefaultValue = 0.75),
        private parSpeedDispersion          is Template_Param_Float( DefaultValue = 0),
        private parCountDebrits             is Template_Param_Int(),
        private parCountDebritsWithSmoke    is Template_Param_Int(),
        private parCountDebritsWithFire     is Template_Param_Int(),
        private parSmokeColor               is Template_Param_Float3(),
        private parSmokeColorMultiplier     is Template_Param_Float(),
        private parSmokeParticleStartSize   is Template_Param_Float(),
        private parSmokeParticleEndSize     is Template_Param_Float(),
        private parFireParticleStartSize    is Template_Param_Float(),
        private parFireParticleEndSize      is Template_Param_Float(),
        private parParticleOpacity          is Template_Param_Float(),
        private parDebritSizeMul            is Template_Param_Float(),
        private parSmokeDensity             is Template_Param_Float(DefaultValue = 100),
        private parMeshType                 is Template_Param_Int(DefaultValue = 1),
    ]
    Action =
    TActionDescriptor_Select
    (
        Index = parMeshType + 1
        Actions = RubbleSelect_List
        (
            Params = MAP
            [
                ( 'BANK_lifetime'                   , parLifetime * RandomRange[0.8, 1.25]),
                ( 'BANK_InitPosition'               , parDispersion * $/VFX_Bank/MinusOneToOneRandomDisc),
                ( 'BANK_rotation'                   , $/VFX_Bank/MinusOneToOneRandomSphereVolume * 15),
                ( 'BANK_speed'                      , parSpeed * RandomRange[parMinSpeedRatio, 1] * NarrowRandomValue[$/VFX_Bank/MinusOneToOneRandomHemisphereSurface, parSpeedDispersion]),
                ( 'BANK_Count_Debrits'              , parCountDebrits),
                ( 'BANK_Count_Debrits_With_Smoke'   , parCountDebritsWithSmoke),
                ( 'BANK_Count_Debrits_With_Fire'    , parCountDebritsWithFire),
                ( 'BANK_Debrits_size_mul'           , parDebritSizeMul * RandomRange[0.5, 1.5]),
                ( 'BANK_SmokeRGBColor'              , LinearColor[parSmokeColor] * RandomRange[0.5,2]),
                ( 'BANK_SmokeColorMultiplier'       , parSmokeColorMultiplier),
                ( 'BANK_SmokeParticleStartSize'     , parSmokeParticleStartSize * RandomRange[0.8, 1.25] ),
                ( 'BANK_SmokeParticleEndSize'       , parSmokeParticleEndSize * RandomRange[0.8, 1.25] ),
                ( 'BANK_FireParticleStartSize'      , parFireParticleStartSize * RandomRange[0.8, 1.25] ),
                ( 'BANK_FireParticleEndSize'        , parFireParticleEndSize * RandomRange[0.8, 1.25] ),
                ( 'BANK_ParticleAlphaMul'           , parParticleOpacity),
                ( 'BANK_SmokeDensity'               , parSmokeDensity),
            ]
        )
    )
)

export BANK_Rubble2_Oriented_Simple is Template_Rubble_Oriented
(
    InverseDir = false
)
export BANK_Rubble2_Oriented_Simple_Reverse is Template_Rubble_Oriented
(
    InverseDir = true
)
template Template_Rubble_Oriented
[
    InverseDir,
]
is Template_ActionWithParameters
(
    Params =
    [
        private parLifetime                 is Template_Param_Float(),
        private parDispersion               is Template_Param_Float(),
        private parDir                      is Template_Param_Float3(),
        private parSpeed                    is Template_Param_Float3(),
        private parNarrowness               is Template_Param_Float(),
        private parCountDebrits             is Template_Param_Int(),
        private parCountDebritsWithSmoke    is Template_Param_Int(),
        private parCountDebritsWithFire     is Template_Param_Int(),
        private parSmokeColor               is Template_Param_Float3(),
        private parSmokeColorMultiplier     is Template_Param_Float(),
        private parSmokeParticleStartSize   is Template_Param_Float(),
        private parSmokeParticleEndSize     is Template_Param_Float(),
        private parFireParticleStartSize    is Template_Param_Float(),
        private parFireParticleEndSize      is Template_Param_Float(),
        private parParticleOpacity          is Template_Param_Float(),
        private parDebritSizeMul            is Template_Param_Float(),
        private parFluidFriction            is Template_Param_Float(DefaultValue = 0.5),
        private parSmokeDensity             is Template_Param_Float(DefaultValue = 100),
        private parMeshType                 is Template_Param_Int(DefaultValue = 1),
        private parGravity                  is Template_Param_Float(DefaultValue = 2000),
    ]
    Action = TActionDescriptor_Select
    (
        Direction is <InverseDir> ? -parDir : parDir
        Index = parMeshType + 1
        Actions = RubbleSelect_List
        (
            Params = MAP
            [
                ( 'BANK_lifetime'                   , parLifetime * RandomRange[0.8, 1.25]),
                ( 'BANK_InitPosition'               , parDispersion * $/VFX_Bank/MinusOneToOneRandomDisc),
                ( 'BANK_rotation'                   , $/VFX_Bank/MinusOneToOneRandomSphereVolume * 15),
                ( 'BANK_speed'                      , ( OrientAndNarrowRandomValue[MinusOneToOneRandomHemisphereSurface, GenFloat3[getX[Direction], getY[Direction],Clamp[getZ[Direction],0.8,1.0] ] , parNarrowness] * RandomRange[0.8, 1] * parSpeed) ),
                ( 'BANK_Count_Debrits'              , parCountDebrits),
                ( 'BANK_Count_Debrits_With_Smoke'   , parCountDebritsWithSmoke),
                ( 'BANK_Count_Debrits_With_Fire'    , parCountDebritsWithFire),
                ( 'BANK_Debrits_size_mul'           , parDebritSizeMul * RandomRange[0.5, 1.5]),
                ( 'BANK_SmokeRGBColor'              , LinearColor[parSmokeColor]),
                ( 'BANK_SmokeColorMultiplier'       , parSmokeColorMultiplier),
                ( 'BANK_SmokeParticleStartSize'     , parSmokeParticleStartSize * RandomRange[0.8, 1.25] ),
                ( 'BANK_SmokeParticleEndSize'       , parSmokeParticleEndSize * RandomRange[0.8, 1.25] ),
                ( 'BANK_FireParticleStartSize'      , parFireParticleStartSize * RandomRange[0.8, 1.25] ),
                ( 'BANK_FireParticleEndSize'        , parFireParticleEndSize * RandomRange[0.8, 1.25] ),
                ( 'BANK_ParticleAlphaMul'           , parParticleOpacity),
                ( 'BANK_FluidFriction'              , parFluidFriction),
                ( 'BANK_SmokeDensity'               , parSmokeDensity),
                ( 'BANK_Gravity'                    , parGravity),
            ]
    )
)
)

BANK_Bomblet_Mesh is TEugBListPBaseClass
(
    Value = [Template_MeshResourcesForFxEditor(Value = "GameData:/Assets/3D/FX/Mesh_Particles/KB44_particle/KB44_particle.fbx")]
)
BANK_Bomblet_MeshTable is Template_MeshTable(Values = BANK_Bomblet_Mesh.Value)

BANK_Bomblet is Template_Rubbles(Meshs = BANK_Bomblet_Mesh)

export BANK_Bomblet_Simple is SimultaneousActionDeclaration
(
    Params =
    [
        private parLifetime                 is Template_Param_Float(),
        private parDispersion               is Template_Param_Float(),
        private parSpeed                    is Template_Param_Float3(),
        private parCountDebrits             is Template_Param_Int(),
        private parDebritSizeMul            is Template_Param_Float(),
        private parDir                      is Template_Param_Float3(),
        private parNarrowness               is Template_Param_Float(),
    ]
    Actions =
    [
        Template_ActionCall
        (
            Action = BANK_Bomblet
            NamedParameters = MAP
            [
                ( 'BANK_lifetime'                   , parLifetime * RandomRange[0.8, 1.25]),
                ( 'BANK_InitPosition'               , parDispersion * $/VFX_Bank/MinusOneToOneRandomDisc),
                ( 'BANK_rotation'                   , 0),
                ( 'BANK_Count_Debrits'              , parCountDebrits),
                ( 'BANK_Count_Debrits_With_Smoke'   , 0),
                ( 'BANK_Count_Debrits_With_Fire'    , 0),
                ( 'BANK_Mesh_Distribution'          , BANK_Bomblet_MeshTable[0]),
                ( 'BANK_Debrits_size_mul'           , parDebritSizeMul * RandomRange[0.5, 1.5]),
                ( 'BANK_speed'                      , ( OrientAndNarrowRandomValue[MinusOneToOneRandomHemisphereSurface, GenFloat3[getX[parDir], getY[parDir],Clamp[getZ[parDir],0.8,1.0] ] , parNarrowness] * RandomRange[0.8, 1] * parSpeed)),
                ( 'BANK_Gravity'                    , 6000),
                ( 'BANK_FluidFriction', 0.2),
            ]
        )
    ]
)


export BANK_Siege_Ejectable_Simple is SimultaneousActionDeclaration
(
