export BANK_Traine_Bombe_Simple is Template_ActionWithParameters
(
    Params =
    [
        private parDisableSFX           is Template_Param_Bool  ( DefaultValue = false ),
        private parMeshId               is Template_Param_Int   ( DefaultValue = 1 ),
        private parSFXId                is Template_Param_Int   ( DefaultValue = 1 ),
        private BombScale               is Template_Param_Float  ( DefaultValue = 1 ),
        private DurationInSec           is Template_Param_Float ( DefaultValue = 1 ),
        private parPowerPinnable        is Template_Param_Float ( DefaultValue = 1 ),
    ]
    Action = TActionDescriptor_Select
    (
        Index = parMeshId + 1
        Actions = Bomb_Model_List.Value
    )
)

template Template_CallBombe
[
    Mesh,
] is Template_ActionCall
(
    Action = Template_TraineBombe(Mesh = Template_MeshResourcesForFxEditor(Value = <Mesh>))
    NamedParameters = MAP
    [
        ( 'parDisableSFX'               , BANK_Traine_Bombe_Simple/parDisableSFX ),
        ( 'parMeshId'                   , BANK_Traine_Bombe_Simple/parMeshId ),
        ( 'parSFXId'                    , BANK_Traine_Bombe_Simple/parSFXId ),
        ( 'BombScale'                   , BANK_Traine_Bombe_Simple/BombScale ),
        ( 'parFlyDuration'              , BANK_Traine_Bombe_Simple/DurationInSec ),
        ( 'parPower'                    , BANK_Traine_Bombe_Simple/parPowerPinnable ),
    ]
)

