//BANK_FlashFaceCam.ndf

export BANK_FlashFaceCam_Test is Simultaneous
(
    Mobile = MobileUnCentroid()
    Actions =
    [
        private test_flash_ground is Template_ActionCall
        (
            Action = ~/BANK_FlashFaceCam
            NamedParameters = MAP[
                ( 'parPosition', float3[0.00, 0.00, 0.00] ),
                ( 'parStartSize', 2000 ),
                ( 'parEndSize', 2000 ),
                ( 'parLifetime', 0.2 ),
                ( 'parColor', GenFloat3[1, 1, 1] ),
                ( 'parColorMultiplier', 1 ),
            ]
        ),
    ]
    MaxDuration = 3
)

export BANK_FlashFaceCam_Simple is ActionCallWithParameters
(
    Action = BANK_FlashFaceCam
    Params =
    [
        private parStartSize        is Template_Param_Float (),
        private parEndSize          is Template_Param_Float (),
        private parLifetime         is Template_Param_Float (),
        private parColor            is Template_Param_Float3 (),
        private parColorMultiplier  is Template_Param_Float (),
        private parRepeatTime       is Template_Param_Float (DefaultValue = 0),
        private parRepeatCount      is Template_Param_Float (DefaultValue = 1),
        private parInitialDelay     is Template_Param_Float (DefaultValue = 0),
    ]
    NamedParameters = MAP
    [
        ( 'parPosition'             , float3[0.00, 0.00, 0.00] ),
        ( 'parStartSize'            , parStartSize * RandomRange[0.8, 1.25] ),
        ( 'parEndSize'              , parEndSize * RandomRange[0.8, 1.25] ),
        ( 'parLifetime'             , parLifetime * RandomRange[0.8, 1.25] ),
        ( 'parColor'                , LinearColor[parColor] ),
        ( 'parColorMultiplier'      , parColorMultiplier *0.1 ),
        ( 'parRepeatTime'           , parRepeatTime ),
        ( 'parRepeatCount'          , parRepeatCount ),
        ( 'parInitialDelay'         , parInitialDelay ),
    ]
)

export BANK_FlashFaceCam is SimultaneousActionDeclaration
(
    Params =
    [
        private parPosition is Template_ActionAlias
        (
            ExpectedType = 'any'
            DefaultValue = float3[0.00, 0.00, 0.00]
        ),
        private parStartSize is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 2000
        ),
        private parEndSize is Template_ActionAlias
        (
            ExpectedType = 'any'
            DefaultValue = 2000
        ),
        private parLifetime is Template_ActionAlias
        (
            ExpectedType = 'any'
            DefaultValue = 0.25
        ),
        private parColor is Template_ActionAlias
        (
            ExpectedType = 'any'
            DefaultValue = float3[1.00, 1.00, 1.00]
        ),
        private parColorMultiplier is Template_ActionAlias
        (
            ExpectedType = 'any'
            DefaultValue = 1
        ),
        private parRepeatTime is Template_ActionAlias
        (
            ExpectedType = 'any'
            DefaultValue = 0
        ),
        private parRepeatCount is Template_ActionAlias
        (
            ExpectedType = 'any'
            DefaultValue = 1
        ),
        private parInitialDelay is Template_ActionAlias
        (
            ExpectedType = 'any'
            DefaultValue = 0
        ),
    ]
    Actions =
    [
        WaitInSec(Duration = parLifetime),
        ParticleSpraySpawnerWithEvaluable
        (
            Frequency = parRepeatTime == 0 ? 10.0 : 1.0 div parRepeatTime
            DurationInSec = parRepeatTime == 0 ? parLifetime : (parRepeatCount == 0 ? 666 : parRepeatTime * (parRepeatCount - 0.9))
            PeriodInSec = parRepeatTime
            InitialDelayInSec = parInitialDelay
            SpawnFirstParticleAtStart = true
            Spawner = ParticleSpawner
            (
                ParticleLifetime = parLifetime
                ParticleDescriptor = ParticleDescriptor
                (
                    ParticleRenderer = $/VFX_Bank/LitParticleRendererNoCentroidPositioning
                    RenderInfo = ParticleRenderInfo
                    (
                        SortTriangles = True
                        TextureName = 'GameData:/Assets/2D/Fx/impactflash.png'
                        Calque = 'Particles'
                        EmissiveParticle = True
                    )

                    Evolvers = ParticleStandardEvolverList
                    (
                        Position = ParticleMobileWrapperPosition + ParticleCustomFloat3_1
                        ZBias = $/VFX_Bank/ParticleSize * 0.5
                        EmissivePower = $/VFX_Bank/ParticleRemainingLifeRatio * $/VFX_Bank/ParticleCustomFloat_2
                        Size = lerp[$/VFX_Bank/ParticleLifeRatio, $/VFX_Bank/ParticleCustomFloat_3, $/VFX_Bank/ParticleCustomFloat_4]
                    )
                )

                Initialisers =
                [
                    Initialiser_SetMobileWrapper(),
                    ParticleInitialiserList
                    (
                        Position = ParticleCustomFloat3_1
                        Size = 1
                        ColorModifier = parColor
                        Opacity = 0
                        Alpha = 1
                        CustomFloat_2 = parColorMultiplier
                        CustomFloat_3 = parStartSize
                        CustomFloat_4 = parEndSize
                        CustomFloat3_1 = parPosition
                    ),
                ]
            )

        ),
    ]
)

