export FX_Feedback_WakeUpThisTurn is Template_FX_Feedback_Screenspace_GoUp
(
    TextureName = "GameData:/Assets/2D/Interface/UseStrategic/Feedback/icone_wakeup.png"
)

template Template_FX_Feedback_Screenspace_GoUp
[
    TextureName : string = nil
] is TSimultaneousAction
(
    LocalVariables =
    [
        private parInitialSize is TPinnableValue(ExpectedType = 'float'    InitialValue = 0.03),
        private parStartZ      is TPinnableValue(ExpectedType = 'float'    InitialValue = 0.04),
        private parEndZ        is TPinnableValue(ExpectedType = 'float'    InitialValue = 0.06)
    ]

    Mobile = TMobileFactoryTransWorldScene2D
    (
        DoNotInheritCentroid = False
        WorldToObserve = $/M3D/Scene/WorldInterface2D
    )

    Actions =
    [
        ParticleBombSpawner
        (
            TimeServer = Zoom_1_2_3_4_RenderTime
            Count = 1
            Spawner = ParticleSpawner
            (
                ParticleLifetime = 0.5
                ParticleDescriptor = ParticleDescriptor
                (
                    RenderInfo = ParticleRenderInfo
                    (
                        TextureName = <TextureName>
                        Calque = FX_Feedback_Calque
                        EmissiveParticle = true
                        ZTest = false
                    )
                    Evolvers = ParticleStandardEvolverList
                    (
                        Position = ParticleCustomFloat3_1 + (lerp[ParticleLifeRatio, ParticleCustomFloat_1, ParticleCustomFloat_2] * dot[(ParticleCustomFloat3_1 - CameraPosition), CameraDirection]) * CameraAxeY
                        ColorMultiplier = ParticleRemainingLifeRatio * ParticleRemainingLifeRatio * ParticleRemainingLifeRatio
                    )
                    ParticleRenderer = ~/ParticleRendererViewPort
                )
                Initialisers =
                [
                    ParticleInitialiserList
                    (
                        ColorRGB = LinearColor[1,1,0.2]
                        ColorMultiplier = 1
                        Opacity = 1
                        Size = parInitialSize

                        CustomFloat3_1 = SpawnerPosition
                        CustomFloat_1 = parStartZ
                        CustomFloat_2 = parEndZ
                    )
                ]
            )
        )
    ]
)

