// ----------------------------------------------------------------------

template Template_FX_Feedback_CenterTexture
[
    CenterLifeTime = 0.8,
    StartCenterSize = 0.03,
    EndCenterSize = 0.12,
    CenterTexture = 'GameData:/Assets/2D/FxFeedback2D/squaretarget.png',
    CenterRotation = 0,
    StartColorMultiplier = 1,
    Color = LinearColor[1,1,1],
] is ParticleBombSpawner
(
    ParticleMaxDurationForSpawnSkip = <CenterLifeTime> * 1.1
    Count = 1
    Spawner = ParticleSpawner
    (
        ParticleDescriptor = ParticleDescriptor
        (
            RenderInfo = ParticleRenderInfo
            (
                OpaqueParticle = True
                //TextureName = 'GameData:/Assets/2D/FxFeedback2D/squaretarget.png'
                TextureName = <CenterTexture>
                Calque = 'Particles'
                ZTest = False
            )
            Evolvers = Template_List
            (
                Evolvers =
                [
                    Template_EvolverSize( EvolveFunction = lerp[ sat[ParticleLifeRatio*2], <StartCenterSize>, <EndCenterSize> ] ),
                    Template_EvolverAlpha( EvolveFunction = ParticleRemainingLifeRatio*ParticleRemainingLifeRatio ),
                ]
            )
            InfiniteParticles = false
            ParticleRenderer = ~/ParticleRendererViewPort
        )
        Initialisers =
        [
            Initialiser_SetMobileWrapper(),
            Initialiser_ColorRGB( InitFunction = <Color> ),
            Initialiser_Alpha( InitFunction = 1 ),
            Initialiser_ColorMultiplier( InitFunction = <StartColorMultiplier> ),
            Initialiser_Rotation( InitFunction = <CenterRotation> ),
        ]
        PostTransformInitialisers =
        [
            Initialiser_Position( InitFunction = ParticleMobileWrapperPositionUnScaled ),
        ]
        ParticleLifetime = <CenterLifeTime>
    )
)

// ----------------------------------------------------------------------

template Template_FX_Feedback_CrossLine
    [
    LineLifeTime = 0.5,
    StartLineSize = 20,
    EndLineSize = 250,
    LineWidth = 0.003,
    StartColorMultiplier = 1,
    Color = LinearColor[1,1,1],
    ] is Simultaneous
(
     Actions =
    [
        HorizontalLines is ParticleBombSpawner
        (
            ParticleMaxDurationForSpawnSkip = <LineLifeTime> * 1.1
            Count = 1
            Spawner = ParticleSpawner
            (
                ParticleDescriptor = ParticleDescriptor
                (
                    RenderInfo = ParticleRenderInfo
                    (
                        OpaqueParticle = True
                        TextureName = 'GameData:/Assets/2D/FxFeedback2D/square_background.png'
                        Calque = FX_Feedback_Calque
                        ZTest = False
                    )
                    Evolvers = Template_List
                    (
                        Evolvers =
                        [
                            Template_EvolverAlpha( EvolveFunction = ParticleRemainingLifeRatio*ParticleRemainingLifeRatio ),
                            Template_EvolverSize( EvolveFunction = <LineWidth> ),
                            Template_EvolverStretching( EvolveFunction = lerp[ParticleLifeRatio*ParticleLifeRatio, <StartLineSize> div <LineWidth>, <EndLineSize> div <LineWidth>] ),
                        ]
                    )
                    InfiniteParticles = false
                    ParticleRenderer = ~/ParticleRendererViewPort
                )
                Initialisers =
                [
                    Initialiser_SetMobileWrapper(),
                    Initialiser_ColorRGB( InitFunction = <Color> ),
                    Initialiser_Alpha( InitFunction = 1 ),
                    Initialiser_ColorMultiplier( InitFunction = <StartColorMultiplier> ),
                ]

                PostTransformInitialisers =
                [
                    Initialiser_Position( InitFunction = ParticleMobileWrapperPositionUnScaled ),
                ]
                ParticleLifetime = <LineLifeTime>
            )
        ),
        VerticalLines is ParticleBombSpawner
        (
            ParticleMaxDurationForSpawnSkip = <LineLifeTime> * 1.1
            Count = 1
            Spawner = ParticleSpawner
            (
                ParticleDescriptor = ParticleDescriptor
                (
                    RenderInfo = ParticleRenderInfo
                    (
                        OpaqueParticle = True
                        TextureName = 'GameData:/Assets/2D/FxFeedback2D/square_background.png'
                        Calque = FX_Feedback_Calque
                        ZTest = False
                    )
                    Evolvers = Template_List
                    (
                        Evolvers =
                        [
                            Template_EvolverAlpha( EvolveFunction = ParticleRemainingLifeRatio*ParticleRemainingLifeRatio ),
                            Template_EvolverSize( EvolveFunction = <LineWidth>),
                            Template_EvolverStretching( EvolveFunction = lerp[ParticleLifeRatio*ParticleLifeRatio, <StartLineSize> div <LineWidth>, <EndLineSize> div <LineWidth>] ),
                        ]
                    )
                    InfiniteParticles = false
                    ParticleRenderer = ~/ParticleRendererViewPort
                )
                Initialisers =
                [
                    Initialiser_SetMobileWrapper(),
                    Initialiser_ColorRGB( InitFunction = <Color> ),
                    Initialiser_Alpha( InitFunction = 1 ),
                    Initialiser_ColorMultiplier( InitFunction = <StartColorMultiplier> ),
                    Initialiser_Rotation( InitFunction = 0.25 ),
                ]
                PostTransformInitialisers =
                [
                    Initialiser_Position( InitFunction = ParticleMobileWrapperPositionUnScaled ),
                ]
                ParticleLifetime = <LineLifeTime>
            )
        ),
    ]
)

// ----------------------------------------------------------------------

template Template_FX_Feedback_CenterTextureAndCross
    [
    CenterLifeTime = 0.8,
    StartCenterSize = 0.03,
    EndCenterSize = 0.12,
    CenterTexture = 'GameData:/Assets/2D/FxFeedback2D/squaretarget.png',
    CenterRotation = 0,
    CenterColor = LinearColor[1,1,1],
    StartColorMultiplier = 10,

    LineLifeTime = 0.5,
    StartLineSize = 20,
    EndLineSize = 250,
    LineWidth = 0.003,

    StartLineColorMultiplier = 10,
    LineColor = LinearColor[1,1,1],
    ] is Simultaneous
(
    Mobile = MobileUnCentroid()
    LocalVariables =
    [
        posmobile is Template_Pinnable(InitialValue = MobilePosition)
    ]
    Actions =
    [
        Simultaneous
        (
            Mobile = TMobileFactoryTransWorldScene2D
            (
                DoNotInheritCentroid = True
                WorldToObserve = $/M3D/Scene/WorldInterface2D
            )

            Actions =
            [
                Template_FX_Feedback_CenterTexture
                (
                    CenterLifeTime = <CenterLifeTime>
                    StartCenterSize = <StartCenterSize>
                    EndCenterSize = <EndCenterSize>
                    CenterTexture = <CenterTexture>
                    CenterRotation = <CenterRotation>
                    Color = <CenterColor>
                    StartColorMultiplier = <StartColorMultiplier>
                ),
                Template_FX_Feedback_CrossLine
                (
                    LineLifeTime = <LineLifeTime>
                    StartLineSize = <StartLineSize>
                    EndLineSize = <EndLineSize>
                    LineWidth = <LineWidth>
                    Color = <LineColor>
                    StartColorMultiplier = <StartLineColorMultiplier>
                ),
                // Pour que le mobile reste vivant jusqu'a la fin de particules
                WaitInSec( Duration = 2 )
            ]
        ),
    ]
)

// ----------------------------------------------------------------------

export FX_Steelman_Combat_Binder is Template_ActionCall
(
    Action = ~/fx_steelman_combat_2
    NamedParameters = MAP[
        ('parPosition', parPosition),
    ]
    LocalVariables =
    [
        private parPosition is Template_Pinnable
        (
            InitialValue = float3[0,0,0]
            ExpectedType = 'float3'
        )
    ]
)

export FX_Steelman_Combat_Interception_Binder is Template_ActionCall
(
    Action = ~/fx_steelman_air_interception
    NamedParameters = MAP[
        ('parPosition', parPosition),
    ]
    LocalVariables =
    [
        private parPosition is Template_Pinnable
        (
            InitialValue = float3[0,0,0]
            ExpectedType = 'float3'
        )
    ]
)
