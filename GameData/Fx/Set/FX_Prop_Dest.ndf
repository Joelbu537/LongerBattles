export Test_Small_Props_Dest is Simultaneous
(
    Mobile = MobileUnCentroid()
    Actions =
    [
        Template_ActionDescriptorDestroySceneryCircle
        (
            Radius = 500
        ),
    ]
)

export FX_Small_Props_Dest is Template_Small_Props_Dest()
export FX_Dest_Pierres is Template_Small_Props_Dest
(
    Fx = $/VFX_Bank/BANK_Debris_Pierres
    Color = LinearColor255[128, 128, 128]
    Distribution = mesh_rubble_pierres[RandomUnit]
)

export FX_Dest_Bois is Template_Small_Props_Dest
(
    Fx = $/VFX_Bank/BANK_Debris_Bois
    Color = LinearColor255[128, 128, 128]
    Distribution = mesh_rubble_bois[RandomUnit]
)

template Template_Small_Props_Dest
[
    Fx = $/VFX_Bank/BANK_Rubble2,
    Color = LinearColor255[77, 77, 77],
    Distribution = mesh_rubble_building[RandomUnit],
] is SimultaneousActionDeclaration
(
    Params =
    [
        private SizeSmoke is Template_Param_Float(),
        private SizeDebris is Template_Param_Float(),
        private NombreDebris is Template_Param_Float(),
    ]
    Actions =
    [
        private Dust is Template_ActionCall
        (
            Action = $/VFX_Bank/BANK_WasteGroundDust
            NamedParameters = MAP[
                ('BANK_ParticleLifetime', RandomRange[1.5, 2.5] ),
                ('BANK_InitRotation', RandomUnit ),
                ('BANK_ParticuleStartSize', 800),
                ('BANK_ParticuleEndSize', 1450),
                ('BANK_ParticleCount', 40),
                ('BANK_ParticleRotationFactor', RandomRange[0.5, 1.5]),
                ('BANK_InitRGBcolor', <Color>),
                ('BANK_EndRGBcolor', <Color>),
                ('BANK_OffsetPos', float3[0,0,0]),
                ('BANK_InitPosition', 200 * MinusOneToOneRandomHemisphereVolume),
                ('BANK_InitSpeed', MinusOneToOneRandomDisc * 1500 * SizeSmoke),
                ('BANK_AlphaMul', RandomRange[3, 7]  ),
                ('BANK_AlphaStartDecayValue', 0.1 ),
                ('BANK_FluidFriction', 1.5 ),
                ('BANK_AccelerationField', $/VFX_Bank/MapWind + float3[0.00, 0.00, 100.00] ),
                ('BANK_ParticuleScaleSizeFactor', RandomRange[0.5, 1.5] * SizeSmoke)
            ]
        ),
        private Rubbles is Template_ActionCall
        (
            Action = <Fx>
            NamedParameters = MAP[
                ('BANK_Mesh_Distribution', <Distribution>),
                ('BANK_Count_Debrits_With_Fire', 0),
                ('BANK_Count_Debrits', NombreDebris),
                ('BANK_Count_Debrits_With_Smoke', 0),
                ('BANK_SmokeRGBColor', <Color>),
                ('BANK_InitPosition', float3[200, 500, 200] * MinusOneToOneRandomHemisphereSurface),
                ('BANK_speed', 2000 * MinusOneToOneRandomHemisphereVolume),
                ('BANK_Debrits_size_mul', RandomRange[0.5, 1.5] * SizeDebris),
                ('BANK_lifetime', RandomRange[1, 2] * SizeDebris),
            ]
        ),
    ]
)

template FX_Small_Props_Descriptor
[
    SizeSmoke = 1,
    SizeDebris = 1,
    NombreDebris = 3,
    FX = $/GFX/GameFx/FX_Small_Props_Dest,
] is TActionCall
(
    Action = <FX>
    NamedParams = MAP
    [
        ('SizeSmoke', <SizeSmoke>),
        ('SizeDebris', <SizeDebris>),
        ('NombreDebris', <NombreDebris>),
    ]
)

export FX_Small_Props_SmokeOnly is FX_Small_Props_Descriptor( SizeSmoke = 2 SizeDebris = 0 NombreDebris = 0)
export FX_Small_Props_Smoke_OneSmallDebris is FX_Small_Props_Descriptor( SizeSmoke = 1 SizeDebris = 0.3 NombreDebris = 1)
export FX_Small_Props_Smoke_ThreeSmallDebris is FX_Small_Props_Descriptor( SizeSmoke = 1 SizeDebris = 0.3 NombreDebris = 3)
