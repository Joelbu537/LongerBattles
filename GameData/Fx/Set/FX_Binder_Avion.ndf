export FX_Binder_Avion_Vortex is SimultaneousActionDeclaration
(
    Params = []
    LocalVariables = []
    Actions =
    [
        Vortex  is ParticleBombSpawner
        (
            ParticleMaxDurationForSpawnSkip = 0
            Count = 1
            Spawner = ParticleSpawner
            (
                ParticleDescriptor = ParticleDescriptor
                (
                    InfiniteParticles = true
                    ParticleRenderer = $/VFX_Bank/NullRenderer
                    RenderInfo = $/VFX_Bank/NullRenderInfo
                    Evolvers = Template_List
                    (
                        Evolvers =
                        [
                            Template_EvolverPosition( EvolveFunction = ParticleMobileWrapperPosition ),
                            TrailSpawner
                            (
                                DistanceBetweenSpawn = 5
                                Spawner = ParticleSpawner
                                (
                                    ParticleDescriptor = ParticleDescriptor
                                    (
                                        RenderInfo = ParticleRenderInfo
                                        (
                                            ZTest = True
                                            ZWrite = False
                                            SortTriangles = True
                                            Use3DRotation = False
                                            TextureName = 'GameData:/Assets/2D/Fx/trail_nuage_strip_32_01.png'
                                            Calque = 'Particles'
                                            OpaqueParticle = True
                                        )
                                        Evolvers = Template_List
                                        (
                                            Evolvers =
                                            [
                                                // on grossit légèrement les trails pour qu'elles soient visible d'un peu plus loin.
                                                ParticleEvolverAntialiasingHelper_Alpha
                                                (
                                                    Size =  60* ( Clamp[ length[CameraPosition - ParticlePosition] div 80000,1,3] )  * (1 - ParticleLifeRatio)
                                                    Alpha = MapToLinearSmoothRect[ ParticleLifeRatio, 0, 0.05, 0.1, 1 ]
                                                ),
                                                Template_EvolverTexCoordU ( EvolveFunction = ParticleCurvilinearAbscissa div 10000),
                                            ]
                                        )
                                        ParticleRenderer = ParticleRendererMeshTrail ( ScalingMode = 1 )
                                    )
                                    Initialisers =
                                    [
                                        ParticleInitialiserList
                                        (
                                            Size = 300
                                            ColorRGB = float3[1, 1, 1]
                                            ColorModifier = float3[1, 1, 1]
                                            Alpha = 1.0

                                            ColorMultiplier = 0
                                            Opacity = 1
                                        )
                                    ]
                                    ParticleLifetime = 0.5
                                )
                            )
                        ]
                    )
                )
                Initialisers =
                [
                    Initialiser_CreateTrailId
                    (
                        OverrideValueFromSpawner = False
                    ),
                    Initialiser_SetMobileWrapper(),
                    Initialiser_Size( InitFunction = 100 ),
                ]
                ParticleLifetime = 1
            )
        ),
        Template_WaitForEver()
    ]
)

export FX_Binder_Avion_Reacteur is template_FX_Binder_Avion_Reacteur
(
    FlammeColorMultiplier = 0.001 //0.08
    FlammeWidthMultiplier = 8 //4.4
    FlammeLengthMultiplier = 8 //3

    Flamme2ColorMultiplier = 0.06 //2
    Flamme2WidthMultiplier = 4 //4.4
    Flamme2LengthMultiplier = 2 //3

    TrailParticleLifeTime = 2 //0.2
    TrailAlpha = 0.10 // 0.3
)

