//FX_Binder_Fire.ndf
export FX_Evironement_Rain is Simultaneous
(
    Actions =
    [
        Template_ActionCall
        (
            Action = Template_FX_Rain(BoxSize = 215 * 75)  //215 * 25
            NamedParameters = MAP[
            ('parDensity', 10),
            ('parMaxZ', 20000),
            ]
            LocalVariables = []
        ),
    ]
)

export Test_RainEffect is Simultaneous
(
    Actions =
    [
        Template_ActionCall
        (
            Action = RainOnScreen
            NamedParameters = MAP[
            ('parMaxZ', 20000),
            ]
            LocalVariables = []
        ),

    ]
)

template Template_FX_Rain
[
    BoxSize = 9000
]is SimultaneousActionDeclaration
(
    Params =
    [
        private parDensity is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 0.5
        ),
        private parMaxZ is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 30000
        ),
    ]
    Actions =
    [
        Simultaneous
        (
            Actions =
            [
                ParticleBombSpawner
                (
                    Count = 1 // cette particule peut ?e tu?iolement par la mort du mobile.
                    Spawner = ParticleSpawner
                    (
                        ParticleLifetime = 666
                        Initialisers =
                        [
                            ParticleInitialiserList
                            (
                                Size = 300
                                ColorRGB = float3[1, 1, 1]
                                ColorModifier = float3[1, 1, 1]
                                Alpha = 1.0
                                ColorMultiplier = 1.0

                                Position = -SpawnerPosition
                                CustomFloat_2 = parMaxZ
                                CustomFloat_1 = 0
                                CustomFloat_3 = parDensity
                            ),
                            TParticleInitialiserWithEvaluable(InitFunction = 10000000 Field=$/Particle/DistanceFromGround),
                        ]
                        ParticleDescriptor = ParticleDescriptor
                        (
                            InfiniteParticles = true
                            ParticleRenderer = $/VFX_Bank/NullRenderer
                            RenderInfo = $/VFX_Bank/NullRenderInfo
                            Evolvers = Template_List
                            (
                                Evolvers =
                                [
                                    EvolverSpraySpawner
                                    (
                                        Frequency = 2 * ParticleCustomFloat_3
                                        MaxSpawnedParticleLifetime = 1
                                        Spawner = ParticleSpawner
                                        (
                                            ParticleLifetime = 1
                                            Initialisers =
                                            [
                                                ParticleInitialiserList
                                                (
                                                    ColorMultiplier = 1
                                                    ColorModifier = LinearColor[0.7, 0.7, 0.7]
                                                    EmissivePower = 1
                                                    Opacity = 0
                                                    CustomFloat3_1 = PositiveUnitRandomBoxVolume * <BoxSize>
                                                    CustomFloat3_3 = (2 + 10 * PositiveUnitRandomSphereVolume) * MapWind + float3[0,0,4300] * 10
                                                    CustomFloat3_2 = ParticleCustomFloat3_1 - ParticleCustomFloat3_3
                                                    CustomFloat_3 = SpawningParticleCustomFloat_2
                                                    CustomFloat_1 = SpawningParticleCustomFloat_1
                                                    CustomFloat3_4 = float3[0,0,0]
                                                    Size = 5
                                                ),
                                            ]
                                            ParticleDescriptor = ParticleDescriptor
                                            (
                                                RenderInfo = ParticleRenderInfo
                                                (
                                                    EmissiveParticle = True
                                                    Calque = 'Particles'
                                                    SortTriangles = true
                                                )
                                                Evolvers = ParticleStandardEvolverList
                                                (
                                                    Direction = normalized[ParticleCustomFloat3_4]
                                                    Stretching = min[100, length[ParticleCustomFloat3_4] * 0.3]
                                                    EmissivePower = ParticleCustomFloat_1 * MapToLinearSmoothRect[ParticleLifeRatio, 0, 0.1, 0.9, 1] * 0.10  //0.05 0.3
                                                    CustomFloat3_4 = ParticleSpeed * EvolverDt - CameraDeltaPosition * 0.25 + 0 * ParticleCustomFloat3_4  //  0.025
                                                    Position= Mod[lerp[ParticleLifeRatio, ParticleCustomFloat3_1, ParticleCustomFloat3_2] - CameraPosition, float3[<BoxSize>,<BoxSize>,<BoxSize>]]
                                                    Speed = (ParticleCustomFloat3_1 - ParticleCustomFloat3_2)
                                                )
                                                ParticleRenderer = ParticleRendererPeriodicBox
                                                (
                                                    BoxSize = GenFloat3[<BoxSize>,<BoxSize>,<BoxSize>]
                                                    XYRepeat = 2 //4
                                                    ZRepeat = 1
                                                )
                                            )
                                        )
                                    ),
                                    Template_ComputeDistanceFromGround( Position = CameraPosition ),
                                    Template_EvolverCustomFloat_1(EvolveFunction=1),
                                ]
                            )
                        )
                    )
                ),
            ]
        )
    ]
)

export RainOnScreen is SimultaneousActionDeclaration
(
    Params =
    [
        private parMaxZ is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 30000
        ),
    ]
    Actions =
    [
    ]
)


export Test_DrunkParticle is Simultaneous
(
    Actions =
    [
        Template_ActionCall
        (
            Action = DrunkParticle
            NamedParameters = MAP[
            ('parMaxZ', 10000),
            ]
            LocalVariables = []
        ),
    ]
)

DrunkWalk is Template_FunctionDeclaration
(
    WindPower is sqrt[dot[parWind,parWind]]
    RandomFactor is min[parDistance, 0.5*WindPower]
    Code = parPos  + RandomFactor * (MinusOneToOneRandomSphereVolume) + parWind * float3[1,1,0.1]
    Params = [parPos is Template_Alias(), parWind is Template_Alias(), parDistance is Template_Alias()]
)

export DrunkParticle is SimultaneousActionDeclaration
(
    Params =
    [
        private parMaxZ is Template_ActionAlias
        (
            ExpectedType = 'float'
            DefaultValue = 10000
        ),
    ]
    Actions =
    [
        Simultaneous
        (
            Actions =
            [
                private stickOnGround is Template_StickMobileOnGround
                (
                    MobileUpMatchWithGroundNormal = True
                    ResetOrientation = True
                ),
                ParticleBombSpawner
                (

                    Count = 1 // cette particule peut etre tuée violement par la mort du mobile.
                    Spawner = ParticleSpawner
                    (
                        Initialisers =
                        [
                            // Pour se lier au lifetime du mobile
                            //Initialiser_SetMobileWrapper(),
                            Initialiser_CustomFloat_2(InitFunction = parMaxZ),
                            TParticleInitialiserWithEvaluable(InitFunction = 10000000 Field=$/Particle/DistanceFromGround),
                            Initialiser_Position(InitFunction = float3[0,0,0]),
                        ]
                        ParticleLifetime = 100
                        ParticleDescriptor = ParticleDescriptor
                        (
                            InfiniteParticles = true
                            ParticleRenderer = $/VFX_Bank/NullRenderer
                            RenderInfo = $/VFX_Bank/NullRenderInfo
                            Evolvers = Template_List
                            (
                                Evolvers =
                                [
                                    EvolverSpraySpawner
                                    (
                                        boxSize is float3[10000,10000,1700]
                                        distance is 5000.0
                                        TickFrequency is 0.5
                                        //Condition = 0.1 < ParticleCustomFloat_1
                                        Frequency = 0.2
                                        MaxSpawnedParticleLifetime = 1
                                        Spawner = ParticleSpawner
                                        (

                                            ParticleLifetime = 1
                                            Initialisers =
                                            [
                                                ParticleInitialiserList
                                                (
                                                    Size = 300
                                                    ColorRGB = float3[1, 1, 1]
                                                    ColorModifier = float3[1, 1, 1]
                                                    Alpha = 1.0
                                                    ColorMultiplier = 1.0

                                                    CustomFloat_2 = SpawningParticleCustomFloat_2
                                                    CustomFloat_3 = RandomRange[2,5]
                                                    CustomFloat3_1 = PositiveUnitRandomHemisphereVolume
                                                    // Position
                                                    CustomFloat3_4 = boxSize * float3[1,1,0.5] * MinusOneToOneRandomBoxVolume //+ CameraPosition * [1,1,0]
                                                    Position = Mod[Mod[ParticleCustomFloat3_4 - CameraPosition - (boxSize div 2), boxSize] + boxSize, boxSize] + CameraPosition - (boxSize div 2)
                                                ),
                                            ]
                                            ParticleDescriptor = ParticleDescriptor
                                            (
                                                ParticleRenderer = $/VFX_Bank/NullRenderer
                                                RenderInfo = $/VFX_Bank/NullRenderInfo
                                                Evolvers = Template_List
                                                (
                                                    Evolvers =
                                                    [
                                                        EvolverSpraySpawner
                                                        (
                                                            Frequency = ParticleCustomFloat_3
                                                            //Condition = ParticleElapsedTime < 1
                                                            MaxSpawnedParticleLifetime = 15
                                                            Spawner = ParticleSpawner
                                                            (

                                                                ParticleLifetime = 15 //ParticleCustomFloat_7
                                                                Initialisers =
                                                                [
                                                                    ParticleInitialiserList
                                                                    (
                                                                        ColorRGB = float3[1, 1, 1]
                                                                        ColorModifier = float3[1, 1, 1]
                                                                        Alpha = 1.0
                                                                        ColorMultiplier = 1.0

                                                                        CustomFloat_2 = SpawningParticleCustomFloat_2
                                                                        // ratio [0,1] time before next drink
                                                                        CustomFloat_3 = getZ[ParticlePosition]
                                                                        // nb particle to spawn
                                                                        CustomFloat_7 = SpawningParticleDuration
                                                                        // Initial Point
                                                                        CustomFloat3_1 = ParticleCustomFloat3_4
                                                                        // Old destination
                                                                        CustomFloat3_2 = DrunkWalk[ParticleCustomFloat3_4, 0.3*MapWind div TickFrequency, distance]
                                                                        // Current destination
                                                                        CustomFloat3_3 = DrunkWalk[ParticleCustomFloat3_2, 0.3*MapWind div TickFrequency, distance]
                                                                        // Position
                                                                        CustomFloat3_4 = SpawningParticlePosition
                                                                        Position = float3[0,0,0]
                                                                        Size = 4
                                                                    ),
                                                                ]
                                                                ParticleDescriptor = ParticleDescriptor
                                                                (
                                                                    RenderInfo = ParticleRenderInfo
                                                                    (
                                                                          OpaqueParticle = True
                                                                        TextureName = 'GameData:/Assets/2D/Fx/poussiere.png'
                                                                        Calque = 'Particles'
                                                                    )
                                                                    Evolvers = Template_List
                                                                    (
                                                                        Evolvers =
                                                                        [
                                                                            ParticleStandardEvolverList
                                                                            (
                                                                                Opacity = 0.5
                                                                                Alpha = 0.5*MapToLinearSmoothRect[ParticleLifeRatio,0, 0.1,0.9,1]
                                                                                CustomFloat_1 = ifte[Creneau[ParticleCustomFloat_4] - Creneau[ParticleCustomFloat_4-ParticleCustomFloat_3] > 0.5, -1, 1]
                                                                                CustomFloat_3 = EvolverDt * TickFrequency
                                                                                CustomFloat_4 = ParticleElapsedTime * TickFrequency
                                                                                CustomFloat_5 = ifte[ParticleCustomFloat_1 < 0, 0, ParticleCustomFloat_5 + ParticleCustomFloat_3]
                                                                                CustomFloat_6 = ifte[ParticleDistanceFromGround>ParticleCustomFloat_2,0,1]
                                                                                CustomFloat3_1 = ifte[ParticleCustomFloat_1 < 0, ParticlePosition, ParticleCustomFloat3_1]
                                                                                CustomFloat3_2 = ifte[ParticleCustomFloat_1 < 0, DrunkWalk[ParticleCustomFloat3_1, 0.3*MapWind div TickFrequency, distance], ParticleCustomFloat3_2]
                                                                                CustomFloat3_3 = ifte[ParticleCustomFloat_1 < 0, DrunkWalk[ParticleCustomFloat3_2, 0.3*MapWind div TickFrequency, distance], ParticleCustomFloat3_3]

                                                                                //ColorRGB = ifte[ParticleCustomFloat_1 < 0, [RandomUnit, RandomUnit, RandomUnit], ParticleColorRGB]
                                                                                CustomFloat3_4 = ParticleCustomFloat3_4 + ParticleCustomFloat_3 * 2 * lerp[ParticleCustomFloat_5, ParticleCustomFloat3_2-ParticleCustomFloat3_1, ParticleCustomFloat3_3-ParticleCustomFloat3_2]
                                                                                //Position = CameraPosition + boxSize
                                                                                AdditionnalEvolvers =
                                                                                [
                                                                                    Template_ComputeDistanceFromGround(Position=CameraPosition),
                                                                                    Template_EvolverPeriodicBoxNoZ(BoxSize= boxSize Position = ParticleCustomFloat3_4 DistanceFromGround = ParticleDistanceFromGround),
                                                                                ]
                                                                            )
                                                                        ]
                                                                    )
                                                                    ParticleRenderer = ParticleRendererPeriodicBox
                                                                    (
                                                                        BoxSize = boxSize
                                                                        XYRepeat = 1
                                                                        ZRepeat = 0
                                                                    )
                                                                )
                                                            )
                                                        ),
                                                        Template_ComputeDistanceFromGround(Position=CameraPosition),
                                                    ]
                                                )
                                            )
                                        )
                                    ),

                                    Template_EvolverCustomFloat_1(EvolveFunction=ifte[ParticleDistanceFromGround>0,ParticleCustomFloat_2-ParticleDistanceFromGround,0]),
                                    Template_ComputeDistanceFromGround(Position=CameraPosition),
                                ]
                            )
                        )
                    )
                )
            ]
        )
    ]
)
