template TemplateTFS_Flag
[
    TextureToken     : string
] is TTFSCommand_UISymbol
(
    TextureToken = <TextureToken>
    BBMin=[0, -0.85, 0]
    BBMax=[1.7, 0.15, 0]
    ShaderDescriptor = $/M3D/Shader/MaterialInterface2D_Blend
)

template TemplateTFS_Division
[
    TextureToken     : string
] is TTFSCommand_UISymbol
(
    TextureToken = <TextureToken>
    BBMin=[0, -1, 0]
    BBMax=[1.5, 0.5, 0]
    ShaderDescriptor = $/M3D/Shader/MaterialInterface2D_Blend
)