private DivisionDisplay_StandoutUnits is BUCKListDescriptor
(
    ComponentFrame = TUIFramePropertyRTTI
    (
        RelativeWidthHeight = [1.0, 0.0]
    )
    Axis = ~/ListAxis/Vertical

    HasBorder = true
    BorderThicknessToken  = "2"
    BorderLineColorToken = "VertLogin"
    BordersToDraw = ~/TBorderSide/Top | ~/TBorderSide/Bottom

    InterItemMargin = TRTTILength( Magnifiable = 4.0 )
    FirstMargin = TRTTILength ( Magnifiable = 16.0)
    LastMargin = TRTTILength( Magnifiable = 16.0 )

    Elements =
    [
        BUCKListElementDescriptor
        (
            ComponentDescriptor = BUCKTextDescriptor
            (
                ComponentFrame = TUIFramePropertyRTTI
                (
                    RelativeWidthHeight = [1.0, 0.0]
                    MagnifiableWidthHeight = [0.0, 32.0]
                )

                HorizontalFitStyle = ~/FitStyle/UserDefined
                VerticalFitStyle = ~/FitStyle/UserDefined
                TextPadding = TRTTILength4(Magnifiable = [0.0, 0.0, 0.0, 0.0])
                ParagraphStyle = paragraphStyleTextCenter
                BigLineAction = ~/BigLineAction/ResizeFont
                TypefaceToken = "IBM"
                TextStyle = "TextStyleEcranMoniteur"
                TextSize = "26"
                TextColor = "White"
                TextToken = "DIV_unit"
                TextDico = ~/LocalisationConstantes/dico_interface_outgame
            )
        ),
        // Filler for units to be centered in the remaining space
        BUCKListElementDescriptor
        (
            ExtendWeight = 1.0
            ComponentDescriptor = BUCKContainerDescriptor(ComponentFrame = TUIFramePropertyRTTI(RelativeWidthHeight = [1.0, 1.0]))
        ),
        BUCKListElementDescriptor
        (
            ComponentDescriptor = BUCKRackDescriptor
            (
                ElementName = "StandOutUnitsRack0"
                Axis = ~/ListAxis/Horizontal
                ComponentFrame = TUIFramePropertyRTTI
                (
                    AlignementToFather = [0.5, 0.0]
                    AlignementToAnchor = [0.5, 0.0]
                )
                BreadthComputationMode = ~/BreadthComputationMode/ComputeBreadthFromLargestChild
                InterItemMargin = TRTTILength( Magnifiable = 4.0 )

                BladeDescriptor = ~/StandoutUnit
            )
        ),
        BUCKListElementDescriptor
        (
            ComponentDescriptor = BUCKRackDescriptor
            (
                ElementName = "StandOutUnitsRack1"
                Axis = ~/ListAxis/Horizontal
                ComponentFrame = TUIFramePropertyRTTI
                (
                    AlignementToFather = [0.5, 0.0]
                    AlignementToAnchor = [0.5, 0.0]
                )
                BreadthComputationMode = ~/BreadthComputationMode/ComputeBreadthFromLargestChild
                InterItemMargin = TRTTILength( Magnifiable = 4.0 )

                BladeDescriptor = ~/StandoutUnit
            )
        ),
        // Filler for units to be centered in the remaining space
        BUCKListElementDescriptor
        (
            ExtendWeight = 1.0
            ComponentDescriptor = BUCKContainerDescriptor(ComponentFrame = TUIFramePropertyRTTI(RelativeWidthHeight = [1.0, 1.0]))
        ),
    ]
)

