private template DivisionSelectionFilterCheckBox
[
    ElementName : string = "",
    TextToken : string = "",
    RadioButtonManager : TBUCKRadioButtonManager = nil,
    TextureToken : string = "",
    TextureColorToken : string = "",
    IconeMagnifiableWidthHeight : float2 = [26.0, 16.0],
    TextureElementName : string = "",
    TextElementName : string = "",
]
is BUCKCheckBoxDescriptor
(
    ElementName = <ElementName>
    ComponentFrame = TUIFramePropertyRTTI()

    FitStyle = ~/ContainerFitStyle/FitToContent
    LeftClickSound = ~/SoundEvent_CheckBoxTick

    RadioButtonManager = <RadioButtonManager>

    Components =
    [
        BUCKListDescriptor
        (
            ComponentFrame = TUIFramePropertyRTTI()

            FirstMargin = TRTTILength(Magnifiable = 8.0)
            InterItemMargin = TRTTILength(Magnifiable = 4.0)
            LastMargin = TRTTILength(Magnifiable = 8.0)
            Axis = ~/ListAxis/Horizontal
            BreadthComputationMode = ~/BreadthComputationMode/ComputeBreadthFromLargestChild

            Elements =
            [
                BUCKListElementDescriptor
                (
                    ComponentDescriptor = BUCKTextureDescriptor
                    (
                        ComponentFrame = TUIFramePropertyRTTI
                        (
                            MagnifiableWidthHeight = [16.0, 16.0]
                            AlignementToAnchor = [0.0, 0.5]
                            AlignementToFather = [0.0, 0.5]
                        )

                        TextureToken = "StyleDeskTexture_CheckBox"
                        TextureColorToken = "VertLogin"
                        HasBorder = true
                        BorderLineColorToken = "VertLogin"
                        BorderThicknessToken = "2"
                    )
                ),
                BUCKListElementDescriptor
                (
                    ComponentDescriptor = BUCKTextureDescriptor
                    (
                        ElementName = <TextureElementName>
                        ComponentFrame = TUIFramePropertyRTTI
                        (
                                MagnifiableWidthHeight = <IconeMagnifiableWidthHeight>
                            )
                        TextureToken = <TextureToken>
                        TextureColorToken = <TextureColorToken>
                    )

                ),
                BUCKListElementDescriptor
                (
                    ComponentDescriptor = BUCKTextDescriptor
                    (
                        ElementName = <TextElementName>

                        ComponentFrame = TUIFramePropertyRTTI
                        (
                            MagnifiableWidthHeight = [230.0, 0.0]
                        )

                        TextDico = ~/LocalisationConstantes/dico_interface_outgame
                        TextToken = <TextToken>
                        TypefaceToken = "IBM"
                        TextStyle = "TextStyleEcranMoniteur"
                        TextSize = "20"
                        TextColor = "White"

                        HorizontalFitStyle = ~/FitStyle/UserDefined
                        VerticalFitStyle = ~/FitStyle/FitToParent

                        ParagraphStyle = TParagraphStyle
                        (
                            VerticalAlignment = ~/UIText_VerticalCenter
                        )
                        TextPadding = TRTTILength4( Magnifiable = [0.0, 0.0, 8.0, 0.0] )
                    )
                ),
            ]
        ),
    ]
)

