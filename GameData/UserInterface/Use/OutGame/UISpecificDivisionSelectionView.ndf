private DisplayFilterForDivision is BUCKListDescriptor
(
    ComponentFrame = TUIFramePropertyRTTI
    (
        MagnifiableWidthHeight = [288.0, 0.0]
    )
    Axis = ~/ListAxis/Vertical
    InterItemMargin = TRTTILength( Magnifiable = 15.0 )
    LastMargin = TRTTILength( Magnifiable = 6.0 )

    HasBorder = true
    BorderThicknessToken  = "2"
    BorderLineColorToken = "VertLogin"

    Elements =
    [
        BUCKListElementDescriptor
        (
            ExtendWeight = 1.0
            ComponentDescriptor = BUCKSpecificScrollingContainerDescriptor
            (
                ElementName = "FiltersScrollingContainer"
                ComponentFrame = TUIFramePropertyRTTI
                (
                    RelativeWidthHeight = [1.0, 1.0]
                )

                HasVerticalScrollbar = true
                ScrollBarBackgroundToken = "Transparent"
                ScrollBarElevatorBackgroundToken = "VertLogin"
                VerticalScrollbarComponentFrame = TUIFramePropertyRTTI
                (
                    MagnifiableWidthHeight = [16.0, 0.0]
                    MagnifiableOffset = [-8.0, 0.0]
                    AlignementToFather = [1.0, 0.0]
                    AlignementToAnchor = [1.0, 0.0]
                )

                Components =
                [
                    BUCKListDescriptor
                    (
                        ComponentFrame = TUIFramePropertyRTTI
                        (
                            MagnifiableWidthHeight = [288.0, 0.0]
                        )
                        Axis = ~/ListAxis/Vertical
                        InterItemMargin = TRTTILength( Magnifiable = 6.0 )

                        Elements =
                        [
                            BUCKListElementDescriptor
                            (
                                ComponentDescriptor = BUCKTextDescriptor
                                (
                                    ComponentFrame = TUIFramePropertyRTTI
                                    (
                                        RelativeWidthHeight = [1.0, 0.0]
                                        MagnifiableWidthHeight = [0.0, 32.0]
                                    )

                                    HorizontalFitStyle = ~/FitStyle/UserDefined
                                    VerticalFitStyle = ~/FitStyle/UserDefined
                                    TextPadding = TRTTILength4(Magnifiable = [0.0, 0.0, 0.0, 0.0])
                                    ParagraphStyle = paragraphStyleTextCenter
                                    TypefaceToken = "IBM"
                                    TextStyle = "TextStyleEcranMoniteur"
                                    TextSize = "26"
                                    TextColor = "White"
                                    TextToken = "BTN_FILCAP"
                                    TextDico = ~/LocalisationConstantes/dico_interface_outgame

                                )
                            ),

                            //=============================================================
                            // COALITION FILTERS
                            //=============================================================

                            BUCKListElementDescriptor
                            (
                                ComponentDescriptor = DivisionSelectionFilterCheckBox
                                (
                                    ElementName = "FilterUnitCoalitionNATOCheckBox"
                                    TextElementName = "FilterUnitCoalitionNATOText"
                                    TextureElementName = "FilterUnitCoalitionNATOTexture"
                                    TextToken = "FLTDK_ALLY"
                                    TextureToken = "CommonTexture_MotherCountryFlag_NATO_small"
                                )
                            ),
                            BUCKListElementDescriptor
                            (
                                ComponentDescriptor = DivisionSelectionFilterCheckBox
                                (
                                    ElementName = "FilterUnitCoalitionPACTCheckBox"
                                    TextElementName = "FilterUnitCoalitionPACTText"
                                    TextureElementName = "FilterUnitCoalitionPACTTexture"
                                    TextToken = "FLTDK_AXE"
                                    TextureToken = "CommonTexture_MotherCountryFlag_PACT_small"
                                )
                            ),

                            BUCKListElementSpacer( Magnifiable = 16.0),

                            //=============================================================
                            // Division Type FILTERS
                            //=============================================================

                            BUCKListElementDescriptor
                            (
                                ComponentDescriptor = BUCKRackDescriptor
                                (
                                    ElementName = "TypeFilterRack"
                                    Axis = ~/ListAxis/Vertical
                                    ComponentFrame = TUIFramePropertyRTTI
                                    (
                                        RelativeWidthHeight = [1.0, 0.0]
                                    )
                                    InterItemMargin = TRTTILength( Magnifiable = 6.0 )
                                    BladeDescriptor = DivisionSelectionFilterCheckBox
                                    (
                                        TextElementName = "Text"
                                        TextureElementName = "Texture"
                                        TextureColorToken = "VertLogin_nonTransparency"
                                    )
                                )
                            ),

                            BUCKListElementSpacer( Magnifiable = 16.0),

                            //=============================================================
                            // NATO Countries FILTERS
                            //=============================================================

                            BUCKListElementDescriptor
                            (
                                ComponentDescriptor = BUCKRackDescriptor
                                (
                                    ElementName = "CountriesFilterRackNATO"
                                    Axis = ~/ListAxis/Vertical
                                    ComponentFrame = TUIFramePropertyRTTI
                                    (
                                        RelativeWidthHeight = [1.0, 0.0]
                                    )
                                    InterItemMargin = TRTTILength( Magnifiable = 6.0 )
                                    BladeDescriptor = DivisionSelectionFilterCheckBox
                                    (
                                        TextElementName = "Text"
                                        TextureElementName = "Texture"
                                    )
                                )
                            ),

                            BUCKListElementSpacer( Magnifiable = 16.0),

                            //=============================================================
                            // PACT Countries FILTERS
                            //=============================================================

                            BUCKListElementDescriptor
                            (
                                ComponentDescriptor = BUCKRackDescriptor
                                (
                                    ElementName = "CountriesFilterRackPACT"
                                    Axis = ~/ListAxis/Vertical
                                    ComponentFrame = TUIFramePropertyRTTI
                                    (
                                        RelativeWidthHeight = [1.0, 0.0]
                                    )
                                    InterItemMargin = TRTTILength( Magnifiable = 6.0 )
                                    BladeDescriptor = DivisionSelectionFilterCheckBox
                                    (
                                        TextElementName = "Text"
                                        TextureElementName = "Texture"
                                    )
                                )
                            ),

                            BUCKListElementSpacer( Magnifiable = 16.0),
                        ]
                    )
                ]
            )
        ),
        BUCKListElementDescriptor
        (
            ComponentDescriptor = SpecificModalButton
            (
                ElementName = "ResetFiltersButton"
                TextToken = "DIV_RESET"
                IsFilled = false
                ButtonAlignementToAnchor = [0.5, 0.0]
                ButtonAlignementToFather = [0.5, 0.0]
            )
        ),
    ]
)

