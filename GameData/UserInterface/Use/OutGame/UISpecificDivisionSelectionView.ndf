private BUCKSpecificDivisionSelectionMainComponentDescriptor is BUCKListDescriptor
(
    ComponentFrame = TUIFramePropertyRTTI
    (

        RelativeWidthHeight = [1.0, 0.0]
        AlignementToAnchor = [0.5, 0.5]
        AlignementToFather = [0.5, 0.5]
    )

    HasBackground = true
    BackgroundBlockColorToken = "Black80"

    Axis = ~/ListAxis/Vertical
    Elements =
    [
        BUCKListElementDescriptor
        (
            ComponentDescriptor = BUCKTextDescriptor
            (
                ElementName = "ScreenName"
                ComponentFrame = TUIFramePropertyRTTI
                (
                    RelativeWidthHeight     = [1.0, 0.0]
                    MagnifiableWidthHeight  = [0.0, 96.0]
                    AlignementToFather  = [0.5, 0.0]
                    AlignementToAnchor  = [0.5, 0.0]
                )

                TextToken = "seldiv"

                ParagraphStyle = paragraphStyleTextCenter
                TextStyle = "TextStyleEcranMoniteur"
                VerticalFitStyle = ~/FitStyle/UserDefined
                TypefaceToken = "IBM"


                TextDico = ~/LocalisationConstantes/dico_interface_outgame
                TextColor       = "White"
                TextSize        = "24"

            )
        ),
        BUCKListElementDescriptor
        (
            ExtendWeight = 1.0
            ComponentDescriptor = BUCKContainerDescriptor
            (
                ElementName = "Content"
                ComponentFrame = TUIFramePropertyRTTI
                (
                    RelativeWidthHeight = [1.0, 1.0]
                    MagnifiableWidthHeight = [-280.0, 0.0]
                    AlignementToFather  = [0.5, 0.0]
                    AlignementToAnchor  = [0.5, 0.0]
                )

                Components =
                [
                    SpecificDivisionSelectionContent
                ]
            )
        ),
        BUCKListElementDescriptor
        (
            ComponentDescriptor = BUCKContainerDescriptor
            (
                ComponentFrame = TUIFramePropertyRTTI
                (
                    RelativeWidthHeight = [1.0, 0.0]
                    MagnifiableWidthHeight = [0.0, 96.0]
                )

                Components =
                [
                    BUCKListDescriptor
                    (
                        ElementName = "ButtonList"
                        ComponentFrame = TUIFramePropertyRTTI
                        (
                            AlignementToFather  = [0.5, 0.5]
                            AlignementToAnchor  = [0.5, 0.5]
                        )

                        Axis = ~/ListAxis/Horizontal
                        BreadthComputationMode = ~/BreadthComputationMode/ComputeBreadthFromLargestChild
                        InterItemMargin = TRTTILength(Magnifiable = 20.0)

                        Elements =
                        [
                            BUCKListElementDescriptor
                            (
                                ComponentDescriptor = SpecificModalButton
                                (
                                    ElementName = "SelectButton"
                                    TextToken = "DS_SELECT"
                                    Mapping = TEugBMutablePBaseClass( Value = TUserInputMapping( KeyboardEventID = UserInputKeyboard/KEY_ENTER ) )
                                    IsFilled = true
                                )
                            ),
                            BUCKListElementDescriptor
                            (
                                ComponentDescriptor = SpecificModalButton
                                (
                                    ElementName = "BackButton"
                                    TextToken = "NV_BACK"
                                    Mapping = TEugBMutablePBaseClass( Value = TUserInputMapping( KeyboardEventID = UserInputKeyboard/KEY_ESCAPE ) )
                                    IsFilled = false
                                )
                            )
                        ]
                    )
                ]
            )
        )
    ]

    BackgroundComponents =
    [
        BUCKTextureDescriptor
        (
            ComponentFrame = TUIFramePropertyRTTI
            (
                RelativeWidthHeight = [1.0, 1.0]
            )
            TextureToken = "Outgame_division_choice"

        ),
        BUCKTextureDescriptor
        (
            ComponentFrame = TUIFramePropertyRTTI
            (
                MagnifiableWidthHeight = [1807.0, 1080.0]
                AlignementToAnchor = [0.5, 0.5]
                AlignementToFather = [0.5, 0.5]
            )
            TextureToken = "Outgame_division_choice_effet"
            TextureDrawer = "MonochromeMonitorEffect"
        ),
    ]
)

