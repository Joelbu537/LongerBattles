export Main is TClusterNdfTransactions
(
    Transactions =
    [
        TNDFTransaction
        (
            BaseName  = 'GFX/DepictionResources'
            NameSpace = 'GFX/DepictionResources'
            ResourcePackName = 'Base'
            Moddable = true

            Files =
            [
                'GameData:/Gameplay/Gfx/DepictionResources/DepictionAnimationOperators.ndf',
            ]
            +
            GeneratedDepictionNdfFiles
        )
    ]
)
